---
import { buildAdminCredentialHash } from "../../lib/admin-hash";
import MainLayout from "../../layouts/MainLayout.astro";
import { buildPageTitle, SITE_NAME } from "../../lib/seo";

const title = buildPageTitle("Quản lý đơn hàng");
const description = `Trình quản trị theo dõi và xử lý đơn hàng của ${SITE_NAME}.`;

const rawAdminUsername = (import.meta.env.ADMIN_USERNAME ?? "").trim();
const rawAdminPassword = (import.meta.env.ADMIN_PASSWORD ?? "").trim();
const configuredTtl = Number(import.meta.env.ADMIN_SESSION_TTL_MINUTES ?? 480);
const adminSessionTtlMinutes = Number.isFinite(configuredTtl) ? Math.max(5, Math.floor(configuredTtl)) : 480;

const adminAuthConfigured = rawAdminUsername.length > 0 && rawAdminPassword.length > 0;
const adminCredentialHash = adminAuthConfigured ? buildAdminCredentialHash(rawAdminUsername, rawAdminPassword) : "";
---

<MainLayout title={title} description={description} noindex>
  <section
    class="admin-dashboard"
    data-admin-orders
    data-admin-auth-configured={adminAuthConfigured ? "true" : "false"}
    data-admin-credential-hash={adminCredentialHash}
    data-admin-session-ttl={String(adminSessionTtlMinutes)}
  >
    <!-- SIDEBAR -->
    <aside class="admin-sidebar" aria-label="Menu quản trị">
      <div class="admin-sidebar__logo">
        <div class="brand__mark brand__mark--sm">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
        </div>
        <div class="brand__text">
          <strong>Đông Admin</strong>
          <span class="brand__tagline">Hệ thống quản lý</span>
        </div>
      </div>

      <nav class="admin-nav">
        <a href="/admin/orders" class="admin-nav__item active" aria-current="page">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="3" y1="9" x2="21" y2="9"></line>
            <line x1="9" y1="21" x2="9" y2="9"></line>
          </svg>
          <span>Đơn hàng</span>
        </a>
        <a href="/admin/vouchers" class="admin-nav__item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
            <line x1="7" y1="7" x2="7.01" y2="7"></line>
          </svg>
          <span>Mã giảm giá</span>
        </a>
        <a href="/" class="admin-nav__item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          <span>Xem cửa hàng</span>
        </a>
      </nav>

      <div class="admin-sidebar__footer">
        <a href="/admin/login?logout=1" class="admin-logout-btn" data-admin-logout>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          <span>Đăng xuất</span>
        </a>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="admin-main">
      <header class="admin-header">
        <div class="admin-header__left">
          <h1>Danh sách đơn hàng</h1>
          <p>Theo dõi và cập nhật trạng thái xử lý đơn hàng.</p>
        </div>
        <div class="admin-header__right">
          <div class="sync-status" data-admin-last-sync>Đang kết nối...</div>
          <button type="button" class="btn-refresh" data-admin-refresh title="Làm mới dữ liệu">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="23 4 23 10 17 10"></polyline>
              <polyline points="1 20 1 14 7 14"></polyline>
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
            </svg>
          </button>
        </div>
      </header>

      <div class="admin-status-bar" data-admin-status hidden></div>

      <!-- STATS GRID -->
      <div class="admin-stats-grid">
        <article class="stat-card">
          <div class="stat-card__icon bg-blue">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </div>
          <div class="stat-card__info">
            <p>Tổng số đơn</p>
            <strong data-stat-total>0</strong>
          </div>
        </article>

        <article class="stat-card">
          <div class="stat-card__icon bg-orange">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="stat-card__info">
            <p>Chờ xử lý</p>
            <strong data-stat-pending>0</strong>
          </div>
        </article>

        <article class="stat-card">
          <div class="stat-card__icon bg-green">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <div class="stat-card__info">
            <p>Đã hoàn tất</p>
            <strong data-stat-completed>0</strong>
          </div>
        </article>

        <article class="stat-card">
          <div class="stat-card__icon bg-purple">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23"></line>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          </div>
          <div class="stat-card__info">
            <p>Doanh thu</p>
            <strong data-stat-revenue>0 ₫</strong>
          </div>
        </article>
      </div>

      <!-- TABLE CARD -->
      <div class="admin-content-card">
        <div class="admin-controls">
          <div class="search-field">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="search" placeholder="Tìm tên khách, SĐT, mã đơn..." data-admin-search autocomplete="off" />
          </div>
          <div class="filter-field">
            <select data-admin-filter aria-label="Lọc theo trạng thái">
              <option value="all">Tất cả trạng thái</option>
              <option value="pending">Chờ xử lý</option>
              <option value="processing">Đang xử lý</option>
              <option value="shipping">Đang giao</option>
              <option value="completed">Hoàn tất</option>
              <option value="cancelled">Đã hủy</option>
            </select>
          </div>
        </div>

        <div class="table-container">
          <table class="admin-table">
            <thead>
              <tr>
                <th class="col-id">Mã đơn</th>
                <th class="col-customer">Khách hàng</th>
                <th class="col-total">Tổng tiền</th>
                <th class="col-status">Trạng thái</th>
                <th class="col-created">Ngày tạo</th>
                <th class="col-action">Thao tác</th>
              </tr>
            </thead>
            <tbody data-admin-table-body>
              <!-- Rows injected by JS -->
            </tbody>
          </table>

          <div class="admin-empty-state" data-admin-empty hidden>
            <div class="empty-icon">📂</div>
            <h3>Không tìm thấy đơn hàng</h3>
            <p>Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm để xem thêm kết quả.</p>
          </div>
        </div>
      </div>
    </main>

    <!-- ROW TEMPLATE -->
    <template data-admin-row-template>
      <tr>
        <td class="cell-id">
          <strong data-order-id></strong>
        </td>
        <td class="cell-customer">
          <div class="customer-info">
            <span class="customer-name" data-order-customer></span>
            <span class="customer-contact" data-order-contact></span>
          </div>
        </td>
        <td class="cell-total">
          <strong class="text-blue" data-order-total></strong>
        </td>
        <td class="cell-status">
          <span class="status-pill" data-order-status></span>
        </td>
        <td class="cell-date">
          <span class="created-at" data-order-created></span>
        </td>
        <td class="cell-action">
          <button type="button" class="btn-view-detail" data-order-view>
            Xem chi tiết
          </button>
        </td>
      </tr>
    </template>

    <!-- ORDER DETAIL MODAL -->
    <div class="order-detail-modal" data-order-modal hidden>
      <button type="button" class="order-detail-modal__backdrop" data-order-modal-close aria-label="Đóng"></button>
      <div class="order-detail-modal__panel" role="dialog" aria-modal="true" aria-labelledby="order-detail-title">
        <div class="order-detail-modal__header">
          <h3 id="order-detail-title">Chi tiết đơn hàng <span data-detail-order-id></span></h3>
          <button type="button" class="order-detail-modal__close" data-order-modal-close aria-label="Đóng popup">✕</button>
        </div>

        <div class="order-detail-modal__body">
          <div class="detail-grid">
            <div class="detail-field">
              <span>Khách hàng</span>
              <strong data-detail-customer></strong>
            </div>
            <div class="detail-field">
              <span>Liên hệ</span>
              <strong data-detail-contact></strong>
            </div>
            <div class="detail-field detail-field--full">
              <span>Địa chỉ giao hàng</span>
              <strong data-detail-address></strong>
            </div>
            <div class="detail-field detail-field--full" data-detail-note-wrap hidden>
              <span>Ghi chú</span>
              <strong data-detail-note></strong>
            </div>
            <div class="detail-field">
              <span>Thanh toán</span>
              <strong data-detail-payment></strong>
            </div>
            <div class="detail-field">
              <span>Trạng thái</span>
              <strong data-detail-status></strong>
            </div>
            <div class="detail-field">
              <span>Ngày tạo</span>
              <strong data-detail-created></strong>
            </div>
            <div class="detail-field">
              <span>Số sản phẩm</span>
              <strong data-detail-count></strong>
            </div>
          </div>

          <div class="detail-divider"></div>

          <h4>Sản phẩm đã đặt</h4>
          <div class="detail-items" data-detail-items></div>

          <div class="detail-totals">
            <div class="detail-total-row">
              <span>Tạm tính</span>
              <strong data-detail-subtotal></strong>
            </div>
            <div class="detail-total-row">
              <span>Phí vận chuyển</span>
              <strong data-detail-shipping></strong>
            </div>
            <div class="detail-total-row text-green" data-detail-discount-row hidden>
              <span>Giảm giá</span>
              <strong data-detail-discount></strong>
            </div>
            <div class="detail-total-row detail-total-row--grand">
              <span>Tổng tiền</span>
              <strong data-detail-total></strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  import { clearAdminSession, isAdminSessionValid } from "../../scripts/admin-auth";

  interface OrderItem {
    name: string;
    price: number;
    quantity: number;
    image: string;
  }

  interface OrderRecord {
    id: string | number | null;
    createdAt: string | null;
    customerName: string;
    customerPhone: string;
    customerEmail: string;
    shippingAddress: string;
    note: string;
    paymentMethod: string;
    status: string;
    subtotal: number;
    shippingFee: number;
    discountAmount?: number;
    total: number;
    items: OrderItem[];
  }

  const STATUS_LABELS: Record<string, string> = {
    pending: "Chờ xử lý",
    processing: "Đang xử lý",
    shipping: "Đang giao",
    completed: "Hoàn tất",
    cancelled: "Đã hủy"
  };

  const PAYMENT_LABELS: Record<string, string> = {
    cod: "Tiền mặt (COD)",
    bank: "Chuyển khoản"
  };

  const currencyFormatter = new Intl.NumberFormat("vi-VN", {
    style: "currency",
    currency: "VND",
    maximumFractionDigits: 0
  });

  const page = document.querySelector<HTMLElement>("[data-admin-orders]");
  const supabaseUrl = (import.meta.env.PUBLIC_SUPABASE_URL ?? "").trim();
  const supabaseKey = (import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "").trim();
  const configuredOrdersTable = (import.meta.env.PUBLIC_SUPABASE_ORDERS_TABLE ?? "").trim();
  const ordersTable = configuredOrdersTable || "astro_orders";

  const toText = (v: unknown) => (typeof v === "string" ? v.trim() : "");
  const toNumber = (v: unknown, fb = 0) => {
    const n = Number(v);
    return Number.isFinite(n) ? n : fb;
  };
  const toRecord = (v: unknown) => (v && typeof v === "object" && !Array.isArray(v) ? (v as Record<string, any>) : null);

  const normalizeItems = (raw: unknown): OrderItem[] => {
    if (!Array.isArray(raw)) return [];
    return raw
      .map((entry) => {
        const item = toRecord(entry);
        if (!item) return null;
        const name = toText(item.name);
        const price = toNumber(item.price);
        const quantity = Math.max(1, Math.floor(toNumber(item.quantity, 1)));
        const image = toText(item.image);
        if (!name || price < 0) return null;
        return { name, price, quantity, image };
      })
      .filter((item): item is OrderItem => Boolean(item));
  };

  const normalizeOrder = (entry: unknown): OrderRecord | null => {
    const rec = toRecord(entry);
    if (!rec) return null;

    const items = normalizeItems(rec.items);
    const subtotal = toNumber(rec.subtotal, items.reduce((sum, item) => sum + item.price * item.quantity, 0));
    const shippingFee = toNumber(rec.shipping_fee, 0);

    return {
      id: rec.id,
      createdAt: toText(rec.created_at) || null,
      customerName: toText(rec.customer_name),
      customerPhone: toText(rec.customer_phone),
      customerEmail: toText(rec.customer_email),
      shippingAddress: toText(rec.shipping_address),
      note: toText(rec.note),
      paymentMethod: toText(rec.payment_method).toLowerCase() || "cod",
      status: toText(rec.status).toLowerCase() || "pending",
      subtotal,
      shippingFee,
      discountAmount: typeof rec.discount_amount !== 'undefined' ? toNumber(rec.discount_amount) : undefined,
      total: toNumber(rec.total, subtotal + shippingFee),
      items
    };
  };

  if (page) {
    const statusNode = page.querySelector<HTMLElement>("[data-admin-status]");
    const searchInput = page.querySelector<HTMLInputElement>("[data-admin-search]");
    const filterSelect = page.querySelector<HTMLSelectElement>("[data-admin-filter]");
    const refreshButton = page.querySelector<HTMLButtonElement>("[data-admin-refresh]");
    const lastSyncNode = page.querySelector<HTMLElement>("[data-admin-last-sync]");
    const tableBody = page.querySelector<HTMLElement>("[data-admin-table-body]");
    const emptyNode = page.querySelector<HTMLElement>("[data-admin-empty]");
    const rowTemplate = page.querySelector<HTMLTemplateElement>("template[data-admin-row-template]");

    const modal = page.querySelector<HTMLElement>("[data-order-modal]");
    const modalCloseButtons = page.querySelectorAll<HTMLElement>("[data-order-modal-close]");
    const detailOrderId = page.querySelector<HTMLElement>("[data-detail-order-id]");
    const detailCustomer = page.querySelector<HTMLElement>("[data-detail-customer]");
    const detailContact = page.querySelector<HTMLElement>("[data-detail-contact]");
    const detailAddress = page.querySelector<HTMLElement>("[data-detail-address]");
    const detailNoteWrap = page.querySelector<HTMLElement>("[data-detail-note-wrap]");
    const detailNote = page.querySelector<HTMLElement>("[data-detail-note]");
    const detailPayment = page.querySelector<HTMLElement>("[data-detail-payment]");
    const detailStatus = page.querySelector<HTMLElement>("[data-detail-status]");
    const detailCreated = page.querySelector<HTMLElement>("[data-detail-created]");
    const detailCount = page.querySelector<HTMLElement>("[data-detail-count]");
    const detailItems = page.querySelector<HTMLElement>("[data-detail-items]");
    const detailSubtotal = page.querySelector<HTMLElement>("[data-detail-subtotal]");
    const detailShipping = page.querySelector<HTMLElement>("[data-detail-shipping]");
    const detailDiscountRow = page.querySelector<HTMLElement>("[data-detail-discount-row]");
    const detailDiscount = page.querySelector<HTMLElement>("[data-detail-discount]");
    const detailTotal = page.querySelector<HTMLElement>("[data-detail-total]");

    const statTotal = page.querySelector<HTMLElement>("[data-stat-total]");
    const statPending = page.querySelector<HTMLElement>("[data-stat-pending]");
    const statCompleted = page.querySelector<HTMLElement>("[data-stat-completed]");
    const statRevenue = page.querySelector<HTMLElement>("[data-stat-revenue]");

    const logoutBtn = page.querySelector<HTMLAnchorElement>("[data-admin-logout]");

    const authConfigured = page.dataset.adminAuthConfigured === "true";
    const credentialHash = (page.dataset.adminCredentialHash ?? "").trim();

    const formatDt = (iso: string | null) => {
      if (!iso) return "--";
      const d = new Date(iso);
      return Number.isNaN(d.getTime()) ? iso : d.toLocaleString("vi-VN", { dateStyle: "short", timeStyle: "short" });
    };

    const getItemCount = (order: OrderRecord) => order.items.reduce((sum, item) => sum + item.quantity, 0);

    const closeModal = () => {
      if (!modal) return;
      modal.hidden = true;
      document.body.classList.remove("is-modal-open");
    };

    const openModal = (order: OrderRecord) => {
      if (!modal) return;

      const orderIdText = order.id ? `#${order.id}` : "#--";
      if (detailOrderId) detailOrderId.textContent = orderIdText;
      if (detailCustomer) detailCustomer.textContent = order.customerName || "Khách lẻ";
      if (detailContact) detailContact.textContent = [order.customerPhone, order.customerEmail].filter(Boolean).join(" • ") || "--";
      if (detailAddress) detailAddress.textContent = order.shippingAddress || "--";
      if (detailPayment) detailPayment.textContent = PAYMENT_LABELS[order.paymentMethod] ?? order.paymentMethod;
      if (detailStatus) detailStatus.textContent = STATUS_LABELS[order.status] ?? "Khác";
      if (detailCreated) detailCreated.textContent = formatDt(order.createdAt);
      if (detailCount) detailCount.textContent = `${getItemCount(order)} sản phẩm`;
      if (detailSubtotal) detailSubtotal.textContent = currencyFormatter.format(order.subtotal);
      if (detailShipping) detailShipping.textContent = currencyFormatter.format(order.shippingFee);
      if (order.discountAmount && order.discountAmount > 0) {
         if (detailDiscountRow) detailDiscountRow.hidden = false;
         if (detailDiscount) detailDiscount.textContent = "-" + currencyFormatter.format(order.discountAmount);
      } else {
         if (detailDiscountRow) detailDiscountRow.hidden = true;
      }
      if (detailTotal) detailTotal.textContent = currencyFormatter.format(order.total);

      if (detailNoteWrap) detailNoteWrap.hidden = !order.note;
      if (detailNote) detailNote.textContent = order.note || "--";

      if (detailItems) {
        detailItems.replaceChildren();

        if (order.items.length === 0) {
          const empty = document.createElement("p");
          empty.className = "detail-items-empty";
          empty.textContent = "Không có dữ liệu sản phẩm.";
          detailItems.append(empty);
        } else {
          order.items.forEach((item) => {
            const row = document.createElement("div");
            row.className = "detail-item-row";

            const left = document.createElement("div");
            left.className = "detail-item-main";

            const name = document.createElement("strong");
            name.textContent = item.name;

            const meta = document.createElement("span");
            meta.textContent = `${item.quantity} × ${currencyFormatter.format(item.price)}`;

            const total = document.createElement("strong");
            total.className = "detail-item-total";
            total.textContent = currencyFormatter.format(item.price * item.quantity);

            left.append(name, meta);
            row.append(left, total);
            detailItems.append(row);
          });
        }
      }

      modal.hidden = false;
      document.body.classList.add("is-modal-open");
    };

    if (!authConfigured || !credentialHash || !isAdminSessionValid(credentialHash)) {
      window.location.href = "/admin/login" + (authConfigured ? "" : "?error=config");
    } else {
      let allOrders: OrderRecord[] = [];
      let isLoading = false;

      const setStatus = (msg: string, kind: "info" | "error") => {
        if (!statusNode) return;
        statusNode.hidden = false;
        statusNode.textContent = msg;
        statusNode.className = `admin-status-bar is-${kind}`;
      };

      const clearStatus = () => {
        if (statusNode) statusNode.hidden = true;
      };

      const renderStats = (orders: OrderRecord[]) => {
        if (statTotal) statTotal.textContent = orders.length.toString();
        if (statPending) statPending.textContent = orders.filter((o) => o.status === "pending").length.toString();
        if (statCompleted) statCompleted.textContent = orders.filter((o) => o.status === "completed").length.toString();
        if (statRevenue) {
          const rev = orders.reduce((sum, o) => sum + o.total, 0);
          statRevenue.textContent = currencyFormatter.format(rev);
        }
      };

      const createRow = (order: OrderRecord) => {
        if (!rowTemplate) return document.createDocumentFragment();
        const f = rowTemplate.content.cloneNode(true) as DocumentFragment;

        const idNode = f.querySelector<HTMLElement>("[data-order-id]");
        const customerNode = f.querySelector<HTMLElement>("[data-order-customer]");
        const contactNode = f.querySelector<HTMLElement>("[data-order-contact]");
        const totalNode = f.querySelector<HTMLElement>("[data-order-total]");
        const statusPill = f.querySelector<HTMLElement>("[data-order-status]");
        const createdNode = f.querySelector<HTMLElement>("[data-order-created]");
        const viewButton = f.querySelector<HTMLButtonElement>("[data-order-view]");

        if (idNode) idNode.textContent = order.id ? `#${order.id}` : "#--";
        if (customerNode) customerNode.textContent = order.customerName || "Khách lẻ";
        if (contactNode) contactNode.textContent = [order.customerPhone, order.customerEmail].filter(Boolean).join(" • ") || "--";
        if (totalNode) totalNode.textContent = currencyFormatter.format(order.total);
        if (statusPill) {
          statusPill.textContent = STATUS_LABELS[order.status] ?? "Khác";
          statusPill.className = `status-pill is-${order.status}`;
        }
        if (createdNode) createdNode.textContent = formatDt(order.createdAt);
        if (viewButton) viewButton.dataset.orderId = String(order.id ?? "");

        return f;
      };

      const renderOrders = () => {
        const kw = searchInput?.value.trim().toLowerCase() || "";
        const st = filterSelect?.value || "all";

        const filtered = allOrders.filter((o) => {
          if (st !== "all" && o.status !== st) return false;
          if (!kw) return true;
          const haystack = `${o.id} ${o.customerName} ${o.customerPhone} ${o.customerEmail} ${o.shippingAddress} ${o.items.map((i) => i.name).join(" ")}`.toLowerCase();
          return haystack.includes(kw);
        });

        renderStats(filtered);
        if (tableBody) {
          tableBody.replaceChildren();
          filtered.forEach((o) => tableBody.append(createRow(o)));
        }
        if (emptyNode) emptyNode.hidden = filtered.length > 0;
      };

      const loadOrders = async (silent = false) => {
        if (isLoading) return;
        isLoading = true;
        if (refreshButton) refreshButton.classList.add("is-spinning");
        if (!silent) setStatus("Đang tải dữ liệu mới nhất...", "info");

        try {
          const params = new URLSearchParams({
            select: "id,created_at,customer_name,customer_phone,customer_email,shipping_address,note,payment_method,status,subtotal,shipping_fee,discount_amount,total,items",
            order: "created_at.desc.nullslast"
          });
          const res = await fetch(`${supabaseUrl}/rest/v1/${ordersTable}?${params}`, {
            headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` }
          });
          if (!res.ok) throw new Error(await res.text());
          const raw = await res.json();
          allOrders = Array.isArray(raw) ? (raw.map(normalizeOrder).filter(Boolean) as OrderRecord[]) : [];
          renderOrders();
          clearStatus();
          if (lastSyncNode) lastSyncNode.textContent = `Cập nhật lúc ${new Date().toLocaleTimeString("vi-VN")}`;
        } catch (e) {
          setStatus(`Lỗi: ${e instanceof Error ? e.message : "Không rõ"}`, "error");
        } finally {
          isLoading = false;
          if (refreshButton) refreshButton.classList.remove("is-spinning");
        }
      };

      tableBody?.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const viewButton = target.closest<HTMLButtonElement>("[data-order-view]");
        if (!viewButton) return;

        const orderId = (viewButton.dataset.orderId ?? "").trim();
        const order = allOrders.find((entry) => String(entry.id ?? "") === orderId);
        if (!order) return;

        openModal(order);
      });

      modalCloseButtons.forEach((button) => button.addEventListener("click", closeModal));

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && modal && !modal.hidden) {
          closeModal();
        }
      });

      searchInput?.addEventListener("input", renderOrders);
      filterSelect?.addEventListener("change", renderOrders);
      refreshButton?.addEventListener("click", () => loadOrders(false));
      logoutBtn?.addEventListener("click", (e) => {
        e.preventDefault();
        clearAdminSession();
        window.location.href = "/admin/login?logout=1";
      });

      loadOrders();
      setInterval(() => loadOrders(true), 60000);
    }
  }
</script>

