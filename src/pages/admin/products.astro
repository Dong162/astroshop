---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { buildPageTitle, SITE_NAME } from "../../lib/seo";
import { getProducts, formatCurrency, getProductStats } from "../../lib/products";

const title = buildPageTitle("Danh sách sản phẩm");
const description = `Xem danh sách sản phẩm đã render trên ${SITE_NAME}.`;

// Fetch stats for dashboard
const stats = await getProductStats();
---

<AdminLayout title={title} description={description} activePage="products">
  <section
    data-admin-products
  >
    <header class="admin-header">
      <div class="admin-header__left">
        <h1>Danh sách sản phẩm</h1>
        <p>Tổng quan các sản phẩm đã render trên website.</p>
      </div>
    </header>

    <!-- STATS GRID -->
    <div class="admin-stats-grid">
      <article class="stat-card">
        <div class="stat-card__icon bg-blue">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
            <line x1="12" y1="22.08" x2="12" y2="12"></line>
          </svg>
        </div>
        <div class="stat-card__info">
          <p>Tổng sản phẩm</p>
          <strong>{stats.total}</strong>
        </div>
      </article>

      <article class="stat-card">
        <div class="stat-card__icon bg-green">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
        </div>
        <div class="stat-card__info">
          <p>Còn hàng</p>
          <strong>{stats.inStock}</strong>
        </div>
      </article>

      <article class="stat-card">
        <div class="stat-card__icon bg-orange">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="15" y1="9" x2="9" y2="15"></line>
            <line x1="9" y1="9" x2="15" y2="15"></line>
          </svg>
        </div>
        <div class="stat-card__info">
          <p>Hết hàng</p>
          <strong>{stats.outOfStock}</strong>
        </div>
      </article>

      <article class="stat-card">
        <div class="stat-card__icon bg-purple">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
        </div>
        <div class="stat-card__info">
          <p>Flash Sale</p>
          <strong>{stats.flash}</strong>
        </div>
      </article>
    </div>

    <!-- TABLE CARD -->
    <div class="admin-content-card">
      <div class="admin-controls">
        <div class="search-field">
          <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="search" placeholder="Tìm theo tên sản phẩm, slug..." data-product-search autocomplete="off" />
        </div>
        <div class="filter-field">
          <select data-product-filter aria-label="Lọc theo tình trạng">
            <option value="all">Tất cả</option>
            <option value="instock">Còn hàng</option>
            <option value="outofstock">Hết hàng</option>
            <option value="flash">Flash Sale</option>
            <option value="popular">Nổi bật</option>
          </select>
        </div>
      </div>

      <div class="table-container">
        <table class="admin-table product-table">
          <thead>
            <tr>
              <th>Ảnh</th>
              <th>Tên sản phẩm</th>
              <th>Slug</th>
              <th>Giá</th>
              <th>Tình trạng</th>
              <th>Tags</th>
              <th class="cell-action">Link</th>
            </tr>
          </thead>
          <tbody data-product-table-body>
            <!-- Rows injected by JS -->
          </tbody>
        </table>

        <!-- Mobile card view -->
        <div class="admin-mobile-cards" data-product-mobile-cards>
          <!-- Cards injected by JS -->
        </div>

        <div class="admin-empty-state" data-product-empty hidden>
          <div class="empty-icon">📦</div>
          <h3>Không tìm thấy sản phẩm</h3>
          <p>Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
        </div>

        <!-- Progressive Loading -->
        <div class="admin-load-more" data-product-load-area hidden>
          <div class="loading-sentinel" data-product-sentinel></div>
          <div class="load-more-action" data-product-see-all-wrap hidden>
            <p>Đã tải hết sản phẩm gợi ý</p>
            <button type="button" class="btn-see-all" data-product-see-all>
              <span>Tải thêm sản phẩm</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m7 13 5 5 5-5M7 6l5 5 5-5"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TABLE ROW TEMPLATE -->
  <template data-product-row-template>
    <tr>
      <td class="cell-thumb">
        <img data-thumb alt="" class="product-thumb" loading="lazy" />
        <div data-thumb-empty class="product-thumb-empty">📦</div>
      </td>
      <td>
        <strong class="product-name-cell" data-name></strong>
      </td>
      <td class="cell-slug">
        <code data-slug></code>
      </td>
      <td>
        <div class="price-cell">
          <strong data-price></strong>
          <s class="price-original" data-price-original hidden></s>
        </div>
      </td>
      <td>
        <span class="status-pill" data-status></span>
      </td>
      <td class="cell-tags" data-tags>
         <!-- Tags injected by JS -->
      </td>
      <td class="cell-action">
        <a data-view-link target="_blank" class="btn-view-detail" title="Xem trang sản phẩm">
          Xem ↗
        </a>
      </td>
    </tr>
  </template>

  <!-- MOBILE CARD TEMPLATE -->
  <template data-product-card-template>
    <div class="mobile-card product-mobile-card">
      <div class="product-mobile-card__header">
        <img data-thumb alt="" class="product-mobile-thumb" loading="lazy" />
        <div data-thumb-empty class="product-mobile-thumb-empty">📦</div>
        <div class="product-mobile-card__info">
          <strong data-name></strong>
          <code class="product-mobile-slug" data-slug></code>
        </div>
      </div>
      <div class="mobile-card__row">
        <span class="mobile-card__label">Giá</span>
        <span class="mobile-card__value is-total" data-price></span>
      </div>
      <div class="mobile-card__row">
        <span class="mobile-card__label">Tình trạng</span>
        <span class="status-pill" data-status></span>
      </div>
      <div class="mobile-card__row">
        <span class="mobile-card__label">Tags</span>
        <span class="mobile-card__value" data-tags></span>
      </div>
      <div class="mobile-card__footer">
        <a data-view-link target="_blank" class="btn-view-detail">Xem trang ↗</a>
      </div>
    </div>
  </template>
</AdminLayout>

<script>
  import { clearAdminSession, isAdminSessionValid, getAdminSessionToken } from "../../scripts/admin-auth";

  const page = document.querySelector<HTMLElement>("[data-admin-products]");
  const supabaseUrl = (import.meta.env.PUBLIC_SUPABASE_URL ?? "").trim();
  const supabaseKey = (import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "").trim();
  const productsTable = (import.meta.env.PUBLIC_SUPABASE_PRODUCTS_TABLE ?? "products").trim();

  if (page) {
    const logoutBtn = document.querySelector<HTMLAnchorElement>("[data-admin-logout]");
    const logoutBtnMobile = document.querySelector<HTMLAnchorElement>("[data-admin-logout-mobile]");

    if (!isAdminSessionValid()) {
      window.location.href = "/admin/login";
    } else {
      const handleLogout = (e: Event) => {
        e.preventDefault();
        clearAdminSession();
        window.location.href = "/admin/login?logout=1";
      };
      logoutBtn?.addEventListener("click", handleLogout);
      logoutBtnMobile?.addEventListener("click", handleLogout);

      const searchInput = page.querySelector<HTMLInputElement>("[data-product-search]");
      const filterSelect = page.querySelector<HTMLSelectElement>("[data-product-filter]");
      const tableBody = page.querySelector<HTMLElement>("[data-product-table-body]");
      const mobileCards = page.querySelector<HTMLElement>("[data-product-mobile-cards]");
      const emptyNode = page.querySelector<HTMLElement>("[data-product-empty]");
      
      const rowTemplate = page.querySelector<HTMLTemplateElement>("template[data-product-row-template]");
      const cardTemplate = page.querySelector<HTMLTemplateElement>("template[data-product-card-template]");

      const loadArea = page.querySelector<HTMLElement>("[data-product-load-area]");
      const sentinel = page.querySelector<HTMLElement>("[data-product-sentinel]");
      const seeAllWrap = page.querySelector<HTMLElement>("[data-product-see-all-wrap]");
      const seeAllBtn = page.querySelector<HTMLButtonElement>("[data-product-see-all]");

      let allProducts: any[] = [];
      let isLoading = false;
      let scrollLoads = 0;
      let hasMoreOnServer = true;
      let currentLimit = 20;

      const formatter = new Intl.NumberFormat("vi-VN", {
        style: "currency",
        currency: "VND",
        maximumFractionDigits: 0
      });

      const createRow = (p: any) => {
        if (!rowTemplate) return document.createDocumentFragment();
        const f = rowTemplate.content.cloneNode(true) as DocumentFragment;
        
        const image = p.images?.[0]?.src || "";
        const thumbImg = f.querySelector<HTMLImageElement>("[data-thumb]");
        const thumbEmpty = f.querySelector<HTMLElement>("[data-thumb-empty]");
        if (image && thumbImg && thumbEmpty) {
          thumbImg.src = image;
          thumbImg.alt = p.name;
          thumbEmpty.hidden = true;
        } else if (thumbImg) {
          thumbImg.hidden = true;
        }

        const name = f.querySelector<HTMLElement>("[data-name]");
        if (name) name.textContent = p.name;

        const slug = f.querySelector<HTMLElement>("[data-slug]");
        if (slug) slug.textContent = p.slug;

        const price = f.querySelector<HTMLElement>("[data-price]");
        const displayPrice = p.sale_price ?? p.regular_price;
        if (price) {
          price.textContent = formatter.format(displayPrice);
          if (p.sale_price) price.classList.add("price-sale");
        }

        const originalPrice = f.querySelector<HTMLElement>("[data-price-original]");
        if (originalPrice && p.sale_price) {
          originalPrice.textContent = formatter.format(p.regular_price);
          originalPrice.hidden = false;
        }

        const status = f.querySelector<HTMLElement>("[data-status]");
        if (status) {
          const isOut = p.stock_status === "outofstock";
          status.textContent = isOut ? "Hết hàng" : "Còn hàng";
          status.className = `status-pill is-${isOut ? "cancelled" : "completed"}`;
        }

        const tags = f.querySelector<HTMLElement>("[data-tags]");
        if (tags) {
          tags.innerHTML = "";
          if (p.flash) tags.innerHTML += '<span class="tag tag--red">⚡ Flash</span> ';
          if (p.is_popular) tags.innerHTML += '<span class="tag tag--orange">🔥 Hot</span>';
          if (!p.flash && !p.is_popular) tags.innerHTML = '<span class="tag tag--gray">—</span>';
        }

        const viewLink = f.querySelector<HTMLAnchorElement>("[data-view-link]");
        if (viewLink) viewLink.href = `/products/${p.slug}/`;

        return f;
      };

      const createCard = (p: any) => {
        if (!cardTemplate) return document.createDocumentFragment();
        const f = cardTemplate.content.cloneNode(true) as DocumentFragment;

        const image = p.images?.[0]?.src || "";
        const thumbImg = f.querySelector<HTMLImageElement>("[data-thumb]");
        const thumbEmpty = f.querySelector<HTMLElement>("[data-thumb-empty]");
        if (image && thumbImg && thumbEmpty) {
          thumbImg.src = image;
          thumbImg.alt = p.name;
          thumbEmpty.hidden = true;
        } else if (thumbImg) {
          thumbImg.hidden = true;
        }

        const name = f.querySelector<HTMLElement>("[data-name]");
        if (name) name.textContent = p.name;

        const slug = f.querySelector<HTMLElement>("[data-slug]");
        if (slug) slug.textContent = p.slug;

        const price = f.querySelector<HTMLElement>("[data-price]");
        const displayPrice = p.sale_price ?? p.regular_price;
        if (price) price.textContent = formatter.format(displayPrice);

        const status = f.querySelector<HTMLElement>("[data-status]");
        if (status) {
          const isOut = p.stock_status === "outofstock";
          status.textContent = isOut ? "Hết hàng" : "Còn hàng";
          status.className = `status-pill is-${isOut ? "cancelled" : "completed"}`;
        }

        const tags = f.querySelector<HTMLElement>("[data-tags]");
        if (tags) {
          let t = "";
          if (p.flash) t += "⚡ Flash ";
          if (p.is_popular) t += "🔥 Hot";
          tags.textContent = t || "—";
        }

        const viewLink = f.querySelector<HTMLAnchorElement>("[data-view-link]");
        if (viewLink) viewLink.href = `/products/${p.slug}/`;

        return f;
      };

      const renderProducts = () => {
        if (tableBody) {
          tableBody.replaceChildren();
          allProducts.forEach(p => tableBody.append(createRow(p)));
        }
        if (mobileCards) {
          mobileCards.replaceChildren();
          allProducts.forEach(p => mobileCards.append(createCard(p)));
        }

        if (emptyNode) emptyNode.hidden = allProducts.length > 0;
        
        if (loadArea) {
           loadArea.hidden = !hasMoreOnServer;
           if (hasMoreOnServer) {
              const reachedLimit = scrollLoads >= 2;
              if (sentinel) sentinel.style.display = reachedLimit ? "none" : "";
              if (seeAllWrap) seeAllWrap.hidden = !reachedLimit;
           }
        }
      };

      const loadProducts = async (append = false) => {
        if (isLoading) return;
        isLoading = true;

        try {
          const kw = searchInput?.value.trim() || "";
          const filter = filterSelect?.value || "all";
          const offset = append ? allProducts.length : 0;
          const limit = currentLimit;

          const params = new URLSearchParams({
            select: "id,name,slug,images,regular_price,sale_price,stock_status,flash,is_popular,status",
            status: "eq.publish",
            order: "created_at.desc",
            limit: String(limit),
            offset: String(offset)
          });

          if (kw) {
             params.set("name", `ilike.*${kw}*`);
          }
          if (filter === "instock") params.set("stock_status", "neq.outofstock");
          if (filter === "outofstock") params.set("stock_status", "eq.outofstock");
          if (filter === "flash") params.set("flash", "eq.true");
          if (filter === "popular") params.set("is_popular", "eq.true");

          const token = getAdminSessionToken();
          const res = await fetch(`${supabaseUrl}/rest/v1/${productsTable}?${params}`, {
            headers: {
              apikey: supabaseKey,
              Authorization: `Bearer ${token}`
            }
          });

          if (!res.ok) throw new Error(await res.text());

          const data = await res.json();
          if (append) {
            allProducts = [...allProducts, ...data];
          } else {
            allProducts = data;
          }

          hasMoreOnServer = data.length >= limit;
          renderProducts();
        } catch (e) {
          console.error("[admin-products] Load failed:", e);
        } finally {
          isLoading = false;
        }
      };

      // Search debounce
      let searchTimeout: any;
      searchInput?.addEventListener("input", () => {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          scrollLoads = 0;
          loadProducts();
        }, 500);
      });

      filterSelect?.addEventListener("change", () => {
        scrollLoads = 0;
        loadProducts();
      });

      if (sentinel) {
        const observer = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting && scrollLoads < 2 && hasMoreOnServer && !isLoading) {
            scrollLoads++;
            loadProducts(true);
          }
        }, { rootMargin: "200px" });
        observer.observe(sentinel);
      }

      seeAllBtn?.addEventListener("click", () => {
        scrollLoads = 0;
        currentLimit = 100; // Load larger batches if user wants more
        loadProducts(true);
      });

      // Initial load
      loadProducts();
    }
  }
</script>

<style>
  /* ── PRODUCT TABLE SPECIFICS ───────────────────────────── */
  .product-table {
    min-width: 900px;
  }

  .cell-thumb {
    width: 60px;
  }

  .product-thumb {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    object-fit: cover;
    border: 1px solid #e8edf3;
  }

  .product-thumb-empty {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: #f1f5f9;
    display: grid;
    place-items: center;
    font-size: 1.4rem;
  }

  .product-name-cell {
    color: #0f172a;
    font-size: 0.88rem;
    font-weight: 700;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: 260px;
  }

  .cell-slug code {
    font-family: "JetBrains Mono", "Fira Code", monospace;
    font-size: 0.78rem;
    background: #f1f5f9;
    color: #475569;
    padding: 3px 8px;
    border-radius: 6px;
    border: 1px solid #e2e8f0;
    word-break: break-all;
  }

  .price-cell {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .price-cell strong {
    font-size: 0.88rem;
    font-weight: 800;
    color: #1d4ed8;
  }

  .price-cell strong.price-sale {
    color: #dc2626;
  }

  .price-original {
    font-size: 0.76rem;
    color: #94a3b8;
  }

  .cell-tags {
    white-space: nowrap;
  }

  .tag {
    display: inline-flex;
    padding: 3px 8px;
    border-radius: 6px;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .tag--red {
    background: #fef2f2;
    color: #dc2626;
  }

  .tag--orange {
    background: #fff7ed;
    color: #ea580c;
  }

  .tag--gray {
    background: transparent;
    color: #cbd5e1;
  }

  /* ── MOBILE PRODUCT CARDS ──────────────────────────────── */
  .product-mobile-card__header {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .product-mobile-thumb {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    object-fit: cover;
    border: 1px solid #e8edf3;
    flex-shrink: 0;
  }

  .product-mobile-thumb-empty {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: #f1f5f9;
    display: grid;
    place-items: center;
    font-size: 1.6rem;
    flex-shrink: 0;
  }

  .product-mobile-card__info {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .product-mobile-card__info strong {
    font-size: 0.9rem;
    font-weight: 700;
    color: #0f172a;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-mobile-slug {
    font-family: "JetBrains Mono", "Fira Code", monospace;
    font-size: 0.72rem;
    background: #f1f5f9;
    color: #64748b;
    padding: 2px 6px;
    border-radius: 4px;
    word-break: break-all;
    display: inline-block;
    max-width: 100%;
  }

  /* Link button for both table and mobile */
  a.btn-view-detail {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  /* ── PROGRESSIVE LOADING ──────────────────────────────── */
  .admin-load-more {
    margin-top: 32px;
    padding: 32px;
    text-align: center;
    border-top: 1px dashed #e2e8f0;
    background: linear-gradient(to bottom, transparent, #f8fafc);
  }

  .loading-sentinel {
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .loading-sentinel::after {
    content: "";
    width: 24px;
    height: 24px;
    border: 3px solid #e2e8f0;
    border-top-color: #2563eb;
    border-radius: 50%;
    animation: spinner 0.8s linear infinite;
  }

  .load-more-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    animation: fadeIn 0.5s ease-out;
  }

  .load-more-action p {
    font-size: 0.9rem;
    color: #64748b;
    margin: 0;
    font-weight: 500;
  }

  .btn-see-all {
    appearance: none;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    color: #1e293b;
    padding: 10px 24px;
    border-radius: 99px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-see-all:hover {
    background: #f1f5f9;
    border-color: #cbd5e1;
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .btn-see-all:active {
    transform: translateY(0);
  }

  @keyframes spinner {
    to { transform: rotate(360deg); }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
