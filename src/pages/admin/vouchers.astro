---
import { buildAdminCredentialHash } from "../../lib/admin-hash";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { buildPageTitle, SITE_NAME } from "../../lib/seo";

const title = buildPageTitle("Quản lý mã giảm giá");
const description = `Trình quản trị theo dõi và xử lý mã giảm giá của ${SITE_NAME}.`;

const rawAdminUsername = (import.meta.env.ADMIN_USERNAME ?? "").trim();
const rawAdminPassword = (import.meta.env.ADMIN_PASSWORD ?? "").trim();
const configuredTtl = Number(import.meta.env.ADMIN_SESSION_TTL_MINUTES ?? 480);
const adminSessionTtlMinutes = Number.isFinite(configuredTtl) ? Math.max(5, Math.floor(configuredTtl)) : 480;

const adminAuthConfigured = rawAdminUsername.length > 0 && rawAdminPassword.length > 0;
const adminCredentialHash = adminAuthConfigured ? buildAdminCredentialHash(rawAdminUsername, rawAdminPassword) : "";
---

<AdminLayout title={title} description={description} activePage="vouchers">
  <section
    data-admin-vouchers
    data-admin-auth-configured={adminAuthConfigured ? "true" : "false"}
    data-admin-credential-hash={adminCredentialHash}
    data-admin-session-ttl={String(adminSessionTtlMinutes)}
  >
    <header class="admin-header">
      <div class="admin-header__left">
        <h1>Danh sách Mã giảm giá</h1>
        <p>Tạo và quản lý các mã quà tặng, giảm giá cho khách hàng.</p>
      </div>
      <div class="admin-header__right">
        <div class="sync-status" data-admin-last-sync>Đang kết nối...</div>
        <button type="button" class="btn-admin-primary" data-admin-add-voucher title="Thêm mã giảm giá mới">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Thêm mã
        </button>
        <button type="button" class="btn-refresh" data-admin-refresh title="Làm mới dữ liệu">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="23 4 23 10 17 10"></polyline>
            <polyline points="1 20 1 14 7 14"></polyline>
            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
          </svg>
        </button>
      </div>
    </header>

    <div class="admin-status-bar" data-admin-status hidden></div>

    <!-- TABLE CARD -->
    <div class="admin-content-card">
      <div class="admin-controls">
        <div class="search-field">
          <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="search" placeholder="Tìm theo mã code..." data-admin-search autocomplete="off" />
        </div>
        <div class="filter-field">
           <select data-admin-filter aria-label="Lọc theo trạng thái">
             <option value="all">Tất cả</option>
             <option value="active">Đang hoạt động</option>
             <option value="inactive">Đã vô hiệu hóa</option>
           </select>
        </div>
      </div>

      <div class="table-container">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Mã Code</th>
              <th>Loại</th>
              <th>Mức giảm</th>
              <th>Trạng thái</th>
              <th>Ngày tạo</th>
              <th class="cell-action">Thao tác</th>
            </tr>
          </thead>
          <tbody data-admin-table-body>
            <!-- Rows injected by JS -->
          </tbody>
        </table>

        <!-- Mobile card view -->
        <div class="admin-mobile-cards" data-admin-mobile-cards></div>

        <div class="admin-empty-state" data-admin-empty hidden>
          <div class="empty-icon">🏷️</div>
          <h3>Không tìm thấy mã giảm giá</h3>
          <p>Thử thay đổi bộ lọc, từ khóa hoặc tạo mã mới.</p>
        </div>
      </div>
    </div>

    <!-- ROW TEMPLATE -->
    <template data-admin-row-template>
      <tr>
        <td class="cell-id">
          <strong data-voucher-code></strong>
        </td>
        <td>
          <span class="voucher-type-tag" data-voucher-type></span>
        </td>
        <td>
          <strong class="text-blue" data-voucher-discount></strong>
        </td>
        <td>
          <span class="status-pill" data-voucher-status></span>
        </td>
        <td>
          <span class="created-at" data-voucher-created></span>
        </td>
        <td class="cell-action">
          <div class="cell-action-group">
            <button type="button" class="btn-view-detail" data-voucher-edit>Sửa</button>
            <button type="button" class="btn-delete" data-voucher-delete>Xóa</button>
          </div>
        </td>
      </tr>
    </template>

    <!-- VOUCHER MODAL -->
    <div class="admin-modal" data-voucher-modal hidden>
      <button type="button" class="admin-modal__backdrop" data-voucher-modal-close aria-label="Đóng"></button>
      <div class="admin-modal__panel voucher-modal-panel" role="dialog" aria-modal="true" aria-labelledby="voucher-modal-title">
        <div class="admin-modal__header">
          <h3 id="voucher-modal-title">Thêm / Sửa mã</h3>
          <button type="button" class="admin-modal__close" data-voucher-modal-close aria-label="Đóng popup">✕</button>
        </div>

        <form class="admin-modal__body" data-voucher-form>
           <input type="hidden" name="id" data-voucher-id />
          <div class="voucher-form-grid">
            <label class="form-field">
              <span class="form-label">Mã code (Ví dụ: GIAM50K) <em>*</em></span>
              <input type="text" name="code" required class="form-input" />
            </label>
            <label class="form-field">
              <span class="form-label">Loại giảm giá</span>
              <select name="discountType" class="form-input">
                 <option value="fixed_amount">Giảm tiền mặt (VND)</option>
                 <option value="percentage">Giảm theo phần trăm (%)</option>
                 <option value="free_shipping">Miễn phí vận chuyển</option>
              </select>
            </label>
            <label class="form-field" data-discount-value-field>
              <span class="form-label">Mức giảm (Tương ứng với loại) <em>*</em></span>
              <input type="number" name="discount" required min="0" class="form-input" />
            </label>
            <label class="form-field">
              <span class="form-label">Trạng thái</span>
              <select name="isActive" class="form-input">
                 <option value="true">Đang hoạt động</option>
                 <option value="false">Vô hiệu hóa</option>
              </select>
            </label>
          </div>
          <div class="voucher-form-actions">
            <button type="button" class="btn-form-secondary" data-voucher-modal-close>Hủy bỏ</button>
            <button type="submit" class="btn-form-primary">Lưu thay đổi</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</AdminLayout>

<script>
  import { clearAdminSession, isAdminSessionValid } from "../../scripts/admin-auth";

  interface VoucherRecord {
    id: number | null;
    code: string;
    discount_type?: string;
    discount_value?: number;
    discount_amount?: number;
    is_active: boolean;
    created_at: string;
  }

  const TYPE_LABELS: Record<string, string> = {
    fixed_amount: "Tiền mặt",
    percentage: "Phần trăm",
    free_shipping: "Miễn phí Ship"
  };

  const currencyFormatter = new Intl.NumberFormat("vi-VN", {
    style: "currency",
    currency: "VND",
    maximumFractionDigits: 0
  });

  const page = document.querySelector<HTMLElement>("[data-admin-vouchers]");
  const supabaseUrl = (import.meta.env.PUBLIC_SUPABASE_URL ?? "").trim();
  const supabaseKey = (import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "").trim();
  const vouchersTable = "astro_vouchers";

  const toText = (v: unknown) => (typeof v === "string" ? v.trim() : "");

  const getDiscountDisplay = (item: VoucherRecord) => {
    const val = item.discount_value !== undefined ? item.discount_value : (item.discount_amount || 0);
    const type = item.discount_type || "fixed_amount";
    if (type === "percentage") return val + "%";
    if (type === "free_shipping") return "Toàn bộ phí Ship";
    return currencyFormatter.format(val);
  };

  if (page) {
    const statusNode = page.querySelector<HTMLElement>("[data-admin-status]");
    const searchInput = page.querySelector<HTMLInputElement>("[data-admin-search]");
    const filterSelect = page.querySelector<HTMLSelectElement>("[data-admin-filter]");
    const refreshButton = page.querySelector<HTMLButtonElement>("[data-admin-refresh]");
    const btnAdd = page.querySelector<HTMLButtonElement>("[data-admin-add-voucher]");
    const lastSyncNode = page.querySelector<HTMLElement>("[data-admin-last-sync]");
    const tableBody = page.querySelector<HTMLElement>("[data-admin-table-body]");
    const mobileCards = page.querySelector<HTMLElement>("[data-admin-mobile-cards]");
    const emptyNode = page.querySelector<HTMLElement>("[data-admin-empty]");
    const rowTemplate = page.querySelector<HTMLTemplateElement>("template[data-admin-row-template]");

    const modal = page.querySelector<HTMLElement>("[data-voucher-modal]");
    const modalCloseButtons = page.querySelectorAll<HTMLElement>("[data-voucher-modal-close]");
    const form = page.querySelector<HTMLFormElement>("[data-voucher-form]");

    const logoutBtn = document.querySelector<HTMLAnchorElement>("[data-admin-logout]");
    const logoutBtnMobile = document.querySelector<HTMLAnchorElement>("[data-admin-logout-mobile]");

    const authConfigured = page.dataset.adminAuthConfigured === "true";
    const credentialHash = (page.dataset.adminCredentialHash ?? "").trim();

    const formatDt = (iso: string | null) => {
      if (!iso) return "--";
      const d = new Date(iso);
      return Number.isNaN(d.getTime()) ? iso : d.toLocaleString("vi-VN", { dateStyle: "short", timeStyle: "short" });
    };

    const closeModal = (e?: Event) => {
      if (e) {
         e.preventDefault();
         e.stopPropagation();
      }
      if (!modal) return;
      modal.hidden = true;
      document.body.classList.remove("is-modal-open");
      if (form) form.reset();
    };

    const openModal = (voucher: VoucherRecord | null = null) => {
      if (!modal || !form) return;
      
      const idInput = form.querySelector('[name="id"]') as HTMLInputElement;
      const codeInput = form.querySelector('[name="code"]') as HTMLInputElement;
      const discountTypeInput = form.querySelector('[name="discountType"]') as HTMLSelectElement;
      const discountInput = form.querySelector('[name="discount"]') as HTMLInputElement;
      const isActiveInput = form.querySelector('[name="isActive"]') as HTMLSelectElement;

      if (voucher) {
        idInput.value = String(voucher.id);
        codeInput.value = voucher.code;
        discountTypeInput.value = voucher.discount_type || "fixed_amount";
        const val = voucher.discount_value !== undefined ? voucher.discount_value : (voucher.discount_amount || 0);
        discountInput.value = String(val);
        isActiveInput.value = voucher.is_active ? "true" : "false";
      } else {
        idInput.value = "";
        codeInput.value = "";
        discountTypeInput.value = "fixed_amount";
        discountInput.value = "";
        isActiveInput.value = "true";
      }
      discountTypeInput.dispatchEvent(new Event("change"));

      modal.hidden = false;
      document.body.classList.add("is-modal-open");
    };

    if (!authConfigured || !credentialHash || !isAdminSessionValid(credentialHash)) {
      window.location.href = "/admin/login" + (authConfigured ? "" : "?error=config");
    } else {
      let allData: VoucherRecord[] = [];
      let isLoading = false;

      const setStatus = (msg: string, kind: "info" | "error" | "success") => {
        if (!statusNode) return;
        statusNode.hidden = false;
        statusNode.textContent = msg;
        statusNode.className = `admin-status-bar is-${kind}`;
        
        if (kind === "success") {
           setTimeout(() => { if(statusNode.textContent === msg) statusNode.hidden = true; }, 3000);
        }
      };

      const clearStatus = () => {
        if (statusNode) statusNode.hidden = true;
      };

      const createRow = (item: VoucherRecord) => {
        if (!rowTemplate) return document.createDocumentFragment();
        const f = rowTemplate.content.cloneNode(true) as DocumentFragment;

        const codeNode = f.querySelector<HTMLElement>("[data-voucher-code]");
        const typeNode = f.querySelector<HTMLElement>("[data-voucher-type]");
        const discountNode = f.querySelector<HTMLElement>("[data-voucher-discount]");
        const statusPill = f.querySelector<HTMLElement>("[data-voucher-status]");
        const createdNode = f.querySelector<HTMLElement>("[data-voucher-created]");
        const editButton = f.querySelector<HTMLButtonElement>("[data-voucher-edit]");
        const deleteButton = f.querySelector<HTMLButtonElement>("[data-voucher-delete]");

        if (codeNode) codeNode.textContent = item.code;
        if (typeNode) typeNode.textContent = TYPE_LABELS[item.discount_type || "fixed_amount"] || (item.discount_type || "fixed_amount");
        if (discountNode) discountNode.textContent = getDiscountDisplay(item);
        if (createdNode) createdNode.textContent = formatDt(item.created_at);
        
        if (statusPill) {
          statusPill.textContent = item.is_active ? "Hoạt động" : "Ngừng";
          statusPill.className = `status-pill is-${item.is_active ? 'completed' : 'cancelled'}`;
        }
        
        if (editButton) editButton.dataset.id = String(item.id ?? "");
        if (deleteButton) deleteButton.dataset.id = String(item.id ?? "");

        return f;
      };

      const createMobileCard = (item: VoucherRecord) => {
        const card = document.createElement("div");
        card.className = "mobile-card";
        card.innerHTML = `
          <div class="mobile-card__top">
            <span class="mobile-card__id">${item.code}</span>
            <span class="status-pill is-${item.is_active ? 'completed' : 'cancelled'}">${item.is_active ? "Hoạt động" : "Ngừng"}</span>
          </div>
          <div class="mobile-card__row">
            <span class="mobile-card__label">Loại</span>
            <span class="mobile-card__value">${TYPE_LABELS[item.discount_type || "fixed_amount"] || "Khác"}</span>
          </div>
          <div class="mobile-card__row">
            <span class="mobile-card__label">Mức giảm</span>
            <span class="mobile-card__value is-total">${getDiscountDisplay(item)}</span>
          </div>
          <div class="mobile-card__row">
            <span class="mobile-card__label">Ngày tạo</span>
            <span class="mobile-card__value">${formatDt(item.created_at)}</span>
          </div>
          <div class="mobile-card__footer">
            <button type="button" class="btn-view-detail" data-voucher-edit data-id="${item.id ?? ""}">Sửa</button>
            <button type="button" class="btn-delete" data-voucher-delete data-id="${item.id ?? ""}">Xóa</button>
          </div>
        `;
        return card;
      };

      const renderTable = () => {
        const kw = searchInput?.value.trim().toLowerCase() || "";
        const st = filterSelect?.value || "all";

        const filtered = allData.filter((o) => {
          if (st === "active" && !o.is_active) return false;
          if (st === "inactive" && o.is_active) return false;
          if (!kw) return true;
          return o.code.toLowerCase().includes(kw);
        });

        // Desktop table
        if (tableBody) {
          tableBody.replaceChildren();
          filtered.forEach((o) => tableBody.append(createRow(o)));
        }

        // Mobile cards
        if (mobileCards) {
          mobileCards.replaceChildren();
          filtered.forEach((o) => mobileCards.append(createMobileCard(o)));
        }

        if (emptyNode) emptyNode.hidden = filtered.length > 0;
      };

      const loadData = async (silent = false) => {
        if (isLoading) return;
        isLoading = true;
        if (refreshButton) refreshButton.classList.add("is-spinning");
        if (!silent) setStatus("Đang tải dữ liệu...", "info");

        try {
          const res = await fetch(`${supabaseUrl}/rest/v1/${vouchersTable}?select=*&order=created_at.desc`, {
            cache: 'no-store',
            headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` }
          });
          if (!res.ok) throw new Error(await res.text());
          const raw = await res.json();
          allData = Array.isArray(raw) ? raw : [];
          renderTable();
          clearStatus();
          if (lastSyncNode) lastSyncNode.textContent = `Cập nhật lúc ${new Date().toLocaleTimeString("vi-VN")}`;
        } catch (e) {
          setStatus(`Lỗi tải mã giảm giá. Xem console.`, "error");
        } finally {
          isLoading = false;
          if (refreshButton) refreshButton.classList.remove("is-spinning");
        }
      };

      // Handle clicks on edit/delete buttons (works for both table and mobile cards)
      page.addEventListener("click", async (event) => {
        const target = event.target as Element;
        
        const editButton = target.closest<HTMLButtonElement>("[data-voucher-edit]");
        if (editButton) {
           const id = editButton.dataset.id;
           const v = allData.find(x => String(x.id) === id);
           if (v) openModal(v);
           return;
        }

        const deleteButton = target.closest<HTMLButtonElement>("[data-voucher-delete]");
        if (deleteButton) {
           const id = deleteButton.dataset.id;
           if(confirm("Bạn có chắc chắn muốn xóa mã này?")) {
              try {
                const res = await fetch(`${supabaseUrl}/rest/v1/${vouchersTable}?id=eq.${id}`, {
                    method: 'DELETE',
                    headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` }
                });
                if (!res.ok) throw new Error("Delete failed");
                setStatus("Xóa thành công", "success");
                loadData(true);
              } catch(e) {
                setStatus("Lỗi khi xóa", "error");
              }
           }
        }
      });

      form?.addEventListener("submit", async(e)=>{
          e.preventDefault();
          const btnSubmit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
          if (btnSubmit) {
              btnSubmit.disabled = true;
              btnSubmit.textContent = "Đang lưu...";
          }

          const fd = new FormData(form);
          let id = fd.get("id")?.toString() || "";
          if (id === "null") id = "";
          
          const code = fd.get("code")?.toString().trim().toUpperCase() || "";
          const discountType = fd.get("discountType")?.toString() || "fixed_amount";
          const discountStr = fd.get("discount")?.toString() || "0";
          const discount = parseInt(discountStr, 10);
          const isActive = fd.get("isActive") === "true";

          const payload: any = {
              code,
              discount_type: discountType,
              discount_value: discount,
              is_active: isActive
          };

          try {
              let res;
              if (id) {
                  res = await fetch(`${supabaseUrl}/rest/v1/${vouchersTable}?id=eq.${id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json', apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` },
                    body: JSON.stringify(payload)
                });
              } else {
                 res = await fetch(`${supabaseUrl}/rest/v1/${vouchersTable}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` },
                    body: JSON.stringify(payload)
                });
              }
              
              if (!res.ok) {
                 const errText = await res.text();
                 throw new Error(errText);
              }
              
              setStatus("Lưu thành công", "success");
              closeModal();
              await loadData(true);
          } catch(err:any) {
              console.error("Voucher Save Error:", err);
              let msg = err.message;
              if (msg.includes('duplicate key value')) {
                  msg = 'Mã giảm giá này đã tồn tại!';
              } else if (msg.includes('row-level security')) {
                  msg = 'Thiếu quyền thao tác. Vui lòng kiểm tra lại RLS trong Supabase.';
              }
              alert("Lỗi: " + msg);
          } finally {
              if (btnSubmit) {
                  btnSubmit.disabled = false;
                  btnSubmit.textContent = "Lưu thay đổi";
              }
          }
      });

      const discountTypeSelect = form?.querySelector<HTMLSelectElement>('[name="discountType"]');
      const discountInputEl = form?.querySelector<HTMLInputElement>('[name="discount"]');
      if (discountTypeSelect && discountInputEl) {
         discountTypeSelect.addEventListener("change", () => {
             if (discountTypeSelect.value === "free_shipping") {
                 discountInputEl.value = "0";
                 discountInputEl.disabled = true;
                 discountInputEl.closest("label")!.style.opacity = "0.5";
             } else {
                 discountInputEl.disabled = false;
                 discountInputEl.closest("label")!.style.opacity = "1";
                 if (discountInputEl.value === "0") discountInputEl.value = "";
             }
         });
      }

      modalCloseButtons.forEach((button) => {
          button.addEventListener("click", closeModal);
      });

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && modal && !modal.hidden) {
          closeModal();
        }
      });

      searchInput?.addEventListener("input", renderTable);
      filterSelect?.addEventListener("change", renderTable);
      refreshButton?.addEventListener("click", () => loadData(false));
      btnAdd?.addEventListener("click", () => openModal(null));

      const handleLogout = (e: Event) => {
        e.preventDefault();
        clearAdminSession();
        window.location.href = "/admin/login?logout=1";
      };
      logoutBtn?.addEventListener("click", handleLogout);
      logoutBtnMobile?.addEventListener("click", handleLogout);

      loadData();
    }
  }
</script>

<style>
  /* ── VOUCHER TYPE TAG ──────────────────────────────── */
  .voucher-type-tag {
    display: inline-flex;
    padding: 4px 10px;
    background: #f1f5f9;
    color: #475569;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* ── ACTION GROUP ──────────────────────────────────── */
  .cell-action-group {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }

  /* ── VOUCHER MODAL PANEL ───────────────────────────── */
  .voucher-modal-panel {
    width: min(560px, 100%);
  }

  .voucher-form-grid {
    display: grid;
    gap: 18px;
  }

  .voucher-form-actions {
    margin-top: 24px;
    display: flex;
    justify-content: flex-end;
    gap: 12px;
  }

  @media (max-width: 900px) {
    .voucher-modal-panel {
      width: 100%;
      max-height: 100vh;
      border-radius: 0;
      height: 100vh;
    }
  }
</style>
