---
import MainLayout from "../layouts/MainLayout.astro";
import { getProducts } from "../lib/products";
import { buildPageTitle } from "../lib/seo";
import { toImageCdn } from "../lib/image-cdn";

const title = buildPageTitle("Tìm kiếm sản phẩm");
const description = "Trang tìm kiếm sản phẩm theo từ khóa.";
// Không tải sẵn sản phẩm ở server để giảm tải DB và thu nhỏ file HTML
---

<MainLayout title={title} description={description} noindex>
  <section class="search-page" data-search-page>
    <div class="section-box search-page__box">
      <div class="search-page__header">
        <h1 data-search-title>Tìm kiếm sản phẩm</h1>
        <p data-search-meta>Nhập từ khóa trên ô tìm kiếm để bắt đầu.</p>
      </div>

      <div class="products-grid" data-search-results></div>

      <div class="empty-state" data-search-empty hidden>
        <h2>Không tìm thấy sản phẩm phù hợp</h2>
        <p>Thử đổi từ khóa ngắn gọn hơn hoặc bỏ dấu tiếng Việt.</p>
        <a href="/" class="search-page__empty-link">Quay lại trang chủ</a>
      </div>

      <div class="search-pagination-controls" data-search-controls hidden>
        <button type="button" class="btn-load-all-results" data-load-all-btn>
          Xem tất cả kết quả
          <span data-remaining-count></span>
        </button>
      </div>

      <div class="scroll-trigger" data-search-trigger></div>
    </div>

    <template data-search-card-template>
      <article class="product-card">
        <a class="product-card__image" data-product-link>
          <img data-product-image alt="" loading="lazy" onerror="this.onerror=null; this.src=this.src.replace(/_256x256|_512x512/, '')" />
          <div class="product-badge product-badge--red" data-product-badge hidden>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" /></svg>
            <span>Flash Sale</span>
          </div>
        </a>

        <div class="product-card__body">
          <div class="rating-line">
            <span class="stars">★★★★★</span>
            <span class="score">5.0/5</span>
            <span class="rating-count">(1)</span>
          </div>

          <h3 class="product-title">
            <a data-product-link data-product-name></a>
          </h3>

          <div class="product-card__footer">
            <div class="price-container">
              <strong data-product-price></strong>
              <s data-product-regular hidden></s>
            </div>

            <button class="cart-add-btn" type="button" aria-label="Thêm vào giỏ hàng" data-product-cart-button>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            </button>
          </div>
        </div>
      </article>
    </template>

  </section>
</MainLayout>

<script>
  import { toImageCdn } from "../lib/image-cdn";

  const searchPage = document.querySelector<HTMLElement>("[data-search-page]");
  const supabaseUrl = (import.meta.env.PUBLIC_SUPABASE_URL ?? "").trim();
  const supabaseKey = (import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "").trim();
  const productsTable = (import.meta.env.PUBLIC_SUPABASE_PRODUCTS_TABLE ?? "products").trim();

  if (searchPage) {
    const titleNode = searchPage.querySelector<HTMLElement>("[data-search-title]");
    const metaNode = searchPage.querySelector<HTMLElement>("[data-search-meta]");
    const resultsNode = searchPage.querySelector<HTMLElement>("[data-search-results]");
    const emptyNode = searchPage.querySelector<HTMLElement>("[data-search-empty]");
    const template = searchPage.querySelector<HTMLTemplateElement>("template[data-search-card-template]");

    const formatter = new Intl.NumberFormat("vi-VN", {
      style: "currency",
      currency: "VND",
      maximumFractionDigits: 0
    });

    const createProductNode = (product: any): DocumentFragment => {
      if (!template) return document.createDocumentFragment();
      const fragment = template.content.cloneNode(true) as DocumentFragment;
      const links = fragment.querySelectorAll<HTMLAnchorElement>("[data-product-link]");
      const image = fragment.querySelector<HTMLImageElement>("[data-product-image]");
      const name = fragment.querySelector<HTMLElement>("[data-product-name]");
      const badge = fragment.querySelector<HTMLElement>("[data-product-badge]");
      const price = fragment.querySelector<HTMLElement>("[data-product-price]");
      const regular = fragment.querySelector<HTMLElement>("[data-product-regular]");
      const cartButton = fragment.querySelector<HTMLButtonElement>("[data-product-cart-button]");
      const productUrl = `/products/${product.slug}/`;

      const cdnImage = toImageCdn(product.images?.[0]?.src ?? "https://placehold.co/800x800/eceff3/1b2430?text=Tap+Hoa+Tech", "256x256");

      links.forEach(link => link.href = productUrl);
      if (image) {
        image.src = cdnImage;
        image.alt = product.name;
      }
      if (name) name.textContent = product.name;
      if (badge) badge.hidden = !product.flash;

      const displayPrice = product.sale_price ?? product.regular_price;
      if (price) {
        price.textContent = formatter.format(displayPrice);
        price.classList.add(product.flash ? "price-red" : "price-blue");
      }
      if (regular && displayPrice < product.regular_price) {
        regular.hidden = false;
        regular.textContent = formatter.format(product.regular_price);
      }

      if (cartButton) {
        cartButton.dataset.addToCart = "";
        cartButton.dataset.productId = String(product.id);
        cartButton.dataset.productSlug = product.slug;
        cartButton.dataset.productName = product.name;
        cartButton.dataset.productPrice = String(displayPrice);
        cartButton.dataset.productRegularPrice = String(product.regular_price);
        cartButton.dataset.productImage = cdnImage;
        cartButton.dataset.productUrl = productUrl;
      }


      return fragment;
    };

    let allProducts: any[] = [];
    let isLoading = false;
    let hasMoreOnServer = true;
    let currentQuery = new URLSearchParams(window.location.search).get("q") ?? "";
    const PAGE_SIZE = 20;

    const updateMeta = () => {
      if (!metaNode) return;
      if (allProducts.length === 0) {
        metaNode.textContent = "Nhập từ khóa trên ô tìm kiếm để bắt đầu.";
      } else {
        metaNode.textContent = `Tìm thấy hơn ${allProducts.length} kết quả phù hợp.`;
      }
    };

    const loadProducts = async (append = false) => {
      if (isLoading || !currentQuery) {
        if (!currentQuery && resultsNode) resultsNode.replaceChildren();
        return;
      }
      isLoading = true;
      if (emptyNode) emptyNode.hidden = true;

      try {
        const offset = append ? allProducts.length : 0;
        const params = new URLSearchParams({
          select: "id,name,slug,images,regular_price,sale_price,flash,status,stock_status",
          status: "eq.publish",
          stock_status: "neq.outofstock",
          order: "created_at.desc",
          limit: String(PAGE_SIZE),
          offset: String(offset),
          name: `ilike.*${currentQuery}*`
        });

        const res = await fetch(`${supabaseUrl}/rest/v1/${productsTable}?${params}`, {
          headers: { apikey: supabaseKey }
        });
        if (!res.ok) throw new Error(await res.text());

        const data = await res.json();
        if (append) {
          allProducts = [...allProducts, ...data];
        } else {
          allProducts = data;
          if (resultsNode) resultsNode.replaceChildren();
        }

        if (resultsNode) {
          data.forEach((p: any) => resultsNode.append(createProductNode(p)));
        }

        hasMoreOnServer = data.length >= PAGE_SIZE;
        if (emptyNode) emptyNode.hidden = allProducts.length > 0;
        updateMeta();
      } catch (e) {
        console.error("[search] Load failed:", e);
      } finally {
        isLoading = false;
      }
    };

    const triggerNode = searchPage.querySelector<HTMLElement>("[data-search-trigger]");
    if (triggerNode) {
       const observer = new IntersectionObserver((entries) => {
         if (entries[0].isIntersecting && hasMoreOnServer && !isLoading) {
            loadProducts(true);
         }
       }, { rootMargin: "400px" });
       observer.observe(triggerNode);
    }

    // Listen to GLOBAL search events (if any) or just the URL
    window.addEventListener("popstate", () => {
      currentQuery = new URLSearchParams(window.location.search).get("q") ?? "";
      if (titleNode) titleNode.textContent = currentQuery ? `Kết quả: ${currentQuery}` : "Tìm kiếm sản phẩm";
      loadProducts(false);
    });

    // Check for custom search event from header
    document.addEventListener("app:search", (e: any) => {
       currentQuery = e.detail.query;
       if (titleNode) titleNode.textContent = currentQuery ? `Kết quả: ${currentQuery}` : "Tìm kiếm sản phẩm";
       loadProducts(false);
    });

    // Initial load
    if (titleNode) titleNode.textContent = currentQuery ? `Kết quả: ${currentQuery}` : "Tìm kiếm sản phẩm";
    loadProducts(false);
  }
</script>

<style>
  :global(body) {
    background: #ffffff;
  }

  .search-page {
    min-height: calc(100vh - 220px);
    padding: 8px 0 96px;
  }

  .search-page__box {
    padding: 22px;
  }

  .search-page__header {
    margin-bottom: 20px;
  }

  .search-page__header h1 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.35rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .search-page__header p {
    margin: 10px 0 0;
    color: #64748b;
  }

  .search-page__empty-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    border-radius: 999px;
    background: #2563eb;
    color: #ffffff;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .search-page {
      padding-bottom: 64px;
    }

    .search-page__box {
      padding: 16px;
    }
  }

  /* ── SEARCH PAGINATION ────────────────────── */
  .search-pagination-controls {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  .btn-load-all-results {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: #f1f5f9;
    color: #1e293b;
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-load-all-results:hover {
    background: #e2e8f0;
    transform: translateY(-2px);
  }

  .btn-load-all-results span {
    color: #64748b;
    font-weight: 500;
    font-size: 0.85rem;
  }

  .scroll-trigger {
    height: 1px;
  }
</style>

