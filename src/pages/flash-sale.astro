---
import MainLayout from "../layouts/MainLayout.astro";
import { formatCurrency, getProducts } from "../lib/products";
import { toImageCdn } from "../lib/image-cdn";
import {
  buildAbsoluteUrl,
  buildBreadcrumbJsonLd,
  buildPageTitle,
  SITE_NAME
} from "../lib/seo";

const PAGE_SIZE = 20;
const firstBatch = await getProducts({ limit: PAGE_SIZE, flash: true, excludeOutOfStock: true });
const siteUrl = Astro.site?.toString() ?? "https://example.com";
const title = buildPageTitle("Flash Sale – Khuyến mãi hot mỗi ngày");
const description = "Tổng hợp tất cả sản phẩm Flash Sale giảm giá sốc tại " + SITE_NAME + ". Số lượng có hạn, mua ngay!";
const structuredData = [
  buildBreadcrumbJsonLd([
    { name: "Trang chủ", url: new URL("/", siteUrl).toString() },
    { name: "Flash Sale", url: new URL("/flash-sale/", siteUrl).toString() }
  ])
];
---

<MainLayout title={title} description={description} structuredData={structuredData}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Trang chủ</a>
    <span>›</span>
    <span>Flash Sale</span>
  </nav>

  <section class="listing-page" data-listing-page>
    <div class="listing-page__header">
      <div class="listing-page__icon listing-page__icon--red">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
      </div>
      <div>
        <h1>Flash Sale</h1>
        <p data-listing-meta>Đang hiển thị {firstBatch.length} sản phẩm</p>
      </div>
    </div>

    <div class="products-grid" data-listing-container>
      {firstBatch.map((product) => {
        const productUrl = `/products/${product.slug}/`;
        const image = toImageCdn(product.images[0]?.src ?? "", "256x256");
        const displayPrice = product.sale_price ?? product.regular_price;
        const discountPercent = product.sale_price
          ? Math.max(1, Math.round((1 - product.sale_price / product.regular_price) * 100))
          : 0;

        return (
          <article class="product-card">
            <a class="product-card__image" href={productUrl}>
              <img src={image} alt={product.name} loading="lazy" onerror="this.onerror=null; this.src=this.src.replace(/[_-]256x256|[_-]512x512/, '')" />
              <div class="product-badge product-badge--red">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                Flash
              </div>
              {discountPercent > 0 && <div class="product-discount-tag">-{discountPercent}%</div>}
            </a>
            <div class="product-card__body">
              <div class="rating-line">
                <span class="stars">★★★★★</span>
                <span class="rating-count">({(product.id % 5) + 3})</span>
              </div>
              <h3 class="product-title"><a href={productUrl}>{product.name}</a></h3>
              <div class="product-card__footer">
                <div class="price-container">
                  <strong class="price-red">{formatCurrency(displayPrice)}</strong>
                  {product.sale_price && <s>{formatCurrency(product.regular_price)}</s>}
                </div>
                <button class="cart-add-btn" type="button" aria-label={`Thêm ${product.name} vào giỏ hàng`} data-add-to-cart data-product-id={product.id} data-product-slug={product.slug} data-product-name={product.name} data-product-price={displayPrice} data-product-regular-price={product.regular_price} data-product-image={image} data-product-url={productUrl}>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                </button>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <div class="infinite-scroll-controls" data-listing-controls hidden>
      <button type="button" class="btn-view-all-huge" data-load-all-btn>
        Xem tất cả sản phẩm Flash Sale
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </button>
    </div>

    <div class="scroll-trigger" data-listing-trigger></div>
  </section>
</MainLayout>

<script>
  import { toImageCdn } from "../lib/image-cdn";

  const page = document.querySelector<HTMLElement>("[data-listing-page]");
  const supabaseUrl = (import.meta.env.PUBLIC_SUPABASE_URL ?? "").trim();
  const supabaseKey = (import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "").trim();
  const productsTable = (import.meta.env.PUBLIC_SUPABASE_PRODUCTS_TABLE ?? "products").trim();

  if (page && supabaseUrl && supabaseKey) {
    const container = page.querySelector<HTMLElement>("[data-listing-container]");
    const trigger = page.querySelector<HTMLElement>("[data-listing-trigger]");
    const controls = page.querySelector<HTMLElement>("[data-listing-controls]");
    const loadAllBtn = page.querySelector<HTMLButtonElement>("[data-load-all-btn]");
    const metaNode = page.querySelector<HTMLElement>("[data-listing-meta]");

    const PAGE_SIZE = 20;
    const MAX_AUTO_LOADS = 3;
    let offset = PAGE_SIZE; // first batch already server-rendered
    let autoLoads = 0;
    let loading = false;
    let exhausted = false;

    const fmt = new Intl.NumberFormat("vi-VN", { style: "currency", currency: "VND", maximumFractionDigits: 0 });

    const createCard = (p: any) => {
      const url = `/products/${p.slug}/`;
      const img = toImageCdn(p.images?.[0]?.src ?? "", "256x256");
      const price = p.sale_price ?? p.regular_price;
      const disc = p.sale_price ? Math.max(1, Math.round((1 - p.sale_price / p.regular_price) * 100)) : 0;

      const article = document.createElement("article");
      article.className = "product-card";
      article.innerHTML = `
        <a class="product-card__image" href="${url}">
          <img src="${img}" alt="${p.name}" loading="lazy" onerror="this.onerror=null; this.src=this.src.replace(/[_-]256x256|[_-]512x512/, '')"/>
          <div class="product-badge product-badge--red"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg> Flash</div>
          ${disc > 0 ? `<div class="product-discount-tag">-${disc}%</div>` : ""}
        </a>
        <div class="product-card__body">
          <div class="rating-line"><span class="stars">★★★★★</span><span class="rating-count">(${(p.id % 5) + 3})</span></div>
          <h3 class="product-title"><a href="${url}">${p.name}</a></h3>
          <div class="product-card__footer">
            <div class="price-container">
              <strong class="price-red">${fmt.format(price)}</strong>
              ${p.sale_price ? `<s>${fmt.format(p.regular_price)}</s>` : ""}
            </div>
            <button class="cart-add-btn" type="button" aria-label="Thêm vào giỏ hàng" data-add-to-cart data-product-id="${p.id}" data-product-slug="${p.slug}" data-product-name="${p.name}" data-product-price="${price}" data-product-regular-price="${p.regular_price}" data-product-image="${img}" data-product-url="${url}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            </button>
          </div>
        </div>`;
      return article;
    };

    const loadMore = async () => {
      if (loading || exhausted) return;
      loading = true;
      try {
        const params = new URLSearchParams({
          select: "id,name,slug,images,regular_price,sale_price,flash,status,stock_status",
          status: "eq.publish",
          flash: "eq.true",
          stock_status: "neq.outofstock",
          order: "created_at.desc",
          limit: String(PAGE_SIZE),
          offset: String(offset)
        });
        const res = await fetch(`${supabaseUrl}/rest/v1/${productsTable}?${params}`, { headers: { apikey: supabaseKey } });
        if (!res.ok) return;
        const data = await res.json();
        if (!container) return;
        const frag = document.createDocumentFragment();
        data.forEach((p: any) => frag.appendChild(createCard(p)));
        container.appendChild(frag);
        offset += data.length;
        if (data.length < PAGE_SIZE) exhausted = true;
        if (metaNode) metaNode.textContent = `Đang hiển thị ${offset} sản phẩm`;
      } finally { loading = false; }
    };

    if (trigger) {
      const obs = new IntersectionObserver((entries) => {
        if (!entries[0].isIntersecting || exhausted) return;
        if (autoLoads < MAX_AUTO_LOADS) { loadMore(); autoLoads++; }
        else { if (controls) controls.hidden = false; obs.unobserve(trigger); }
      }, { rootMargin: "300px" });
      obs.observe(trigger);

      loadAllBtn?.addEventListener("click", async () => {
        while (!exhausted) await loadMore();
        if (controls) controls.hidden = true;
      });
    }
  }
</script>

<style>
  .listing-page { padding: 8px 0 80px; }
  .listing-page__header { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; }
  .listing-page__icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 14px; flex-shrink: 0; }
  .listing-page__icon--red { background: var(--red-light); color: var(--red); }
  .listing-page__header h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); line-height: 1.15; }
  .listing-page__header p { margin: 4px 0 0; color: var(--muted-light); font-size: 0.9rem; }
  .scroll-trigger { height: 1px; }
</style>
