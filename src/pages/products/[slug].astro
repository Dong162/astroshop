---
import MainLayout from "../../layouts/MainLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { formatCurrency, getProducts } from "../../lib/products";
import type { Product } from "../../types/product";
import {
  buildBreadcrumbJsonLd,
  buildPageTitle,
  buildProductJsonLd,
  buildProductSeoDescription
} from "../../lib/seo";

export async function getStaticPaths() {
  const products = await getProducts();
  const getSuggestedProducts = (currentProduct: Product, allProducts: Product[], limit = 4): Product[] => {
    const activeProducts = allProducts.filter(item => item.stock_status !== "outofstock");
    const otherProducts = activeProducts.filter((item) => item.id !== currentProduct.id);

    const normalizedCategories = new Set(currentProduct.categories.map(c => c.toLowerCase()));
    
    const sameCategory = otherProducts.filter((item) =>
      item.categories.some((category) => normalizedCategories.has(category.toLowerCase()))
    );

    const fallback = otherProducts.filter(
      (item) => !sameCategory.some((candidate) => candidate.id === item.id)
    );

    return [...sameCategory, ...fallback].slice(0, limit);
  };

  return products.map((product) => ({
    params: { slug: product.slug },
    props: {
      product,
      suggestedProducts: getSuggestedProducts(product, products)
    }
  }));
}

interface PageProps {
  product: Product;
  suggestedProducts: Product[];
}

const { product, suggestedProducts = [] } = Astro.props as PageProps;
const gallery =
  product.images.length > 0
    ? product.images
    : [{ src: "https://placehold.co/1200x1200/f3f4f6/111827?text=Đông+Tạp+Hóa" }];
const displayPrice = product.sale_price ?? product.regular_price;
const descriptionLines = product.description.split("\n").filter(Boolean);
const siteUrl = Astro.site?.toString() ?? "https://example.com";
const seoTitle = buildPageTitle(product.name);
const seoDescription = buildProductSeoDescription(product);
const discountPercent = product.sale_price
  ? Math.max(1, Math.round((1 - product.sale_price / product.regular_price) * 100))
  : 0;
const productUrl = `/products/${product.slug}/`;
const structuredData = [
  buildBreadcrumbJsonLd([
    { name: "Trang chủ", url: new URL("/", siteUrl).toString() },
    ...(product.categories[0] ? [{ 
      name: product.categories[0], 
      url: new URL(`/search?q=${encodeURIComponent(product.categories[0])}`, siteUrl).toString() 
    }] : []),
    { name: product.name, url: new URL(productUrl, siteUrl).toString() }
  ]),
  buildProductJsonLd(product, siteUrl)
];
---

<MainLayout
  title={seoTitle}
  description={seoDescription}
  image={gallery[0].src}
  type="product"
  structuredData={structuredData}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Trang chủ</a>
    <span>›</span>
    {product.categories[0] && (
      <>
        <a href={`/search?q=${encodeURIComponent(product.categories[0])}`}>{product.categories[0]}</a>
        <span>›</span>
      </>
    )}
    <span>{product.name}</span>
  </nav>

  <section class="product-detail">
    <!-- Gallery -->
    <div class="product-detail__gallery">
      <div class="gallery-main-wrap">
        <img
          id="main-product-image"
          class="product-gallery__main"
          src={gallery[0].src}
          alt={product.name}
        />
        {discountPercent > 0 && (
          <div class="gallery-discount-badge">-{discountPercent}%</div>
        )}
      </div>

      {gallery.length > 1 && (
        <div class="product-gallery__thumbs" id="product-thumbnails">
          {gallery.slice(0, 5).map((image, index) => (
            <button
              type="button"
              class={`thumb-btn ${index === 0 ? 'active' : ''}`}
              data-image={image.src}
              aria-label={`Xem ảnh ${index + 1}`}
            >
              <img src={image.src} alt={`${product.name} - ảnh ${index + 1}`} loading="lazy" />
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- Summary -->
    <div class="product-detail__summary">
      <div class="summary-badges">
        {product.flash && <span class="badge-flash">⚡ Flash Sale</span>}
        {product.is_popular && <span class="badge-popular">🔥 Bán chạy</span>}
        {product.stock_status === "outofstock" ? (
          <span class="badge-outofstock">❌ Tạm hết hàng</span>
        ) : (
          <span class="badge-instock">✓ Còn hàng</span>
        )}
      </div>

      <h1>{product.name}</h1>

      <div class="rating-line">
        <span class="stars">★★★★★</span>
        <span class="score">5.0/5</span>
        <span class="rating-count">(1 đánh giá)</span>
      </div>

      <div class="price-block price-block--huge">
        <strong>{formatCurrency(displayPrice)}</strong>
        {product.sale_price && (
          <div class="price-old-row">
            <s>{formatCurrency(product.regular_price)}</s>
            <span class="discount-badge">Tiết kiệm {discountPercent}%</span>
          </div>
        )}
      </div>

      {product.short_description && (
        <p class="product-summary">{product.short_description}</p>
      )}

      <!-- CTA Buttons -->
      {product.stock_status !== "outofstock" ? (
        <div class="cta-panel-grid">
          <button
            class="btn-outline-blue"
            type="button"
            aria-label={`Thêm ${product.name} vào giỏ hàng`}
            data-add-to-cart
            data-added-text="Đã thêm vào giỏ"
            data-product-id={product.id}
            data-product-slug={product.slug}
            data-product-name={product.name}
            data-product-price={displayPrice}
            data-product-regular-price={product.regular_price}
            data-product-image={gallery[0].src}
            data-product-url={productUrl}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            <span data-add-to-cart-label>Thêm vào giỏ hàng</span>
          </button>
          <button class="btn-solid-red" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
            Mua ngay
          </button>
        </div>
      ) : (
        <div class="cta-panel-grid" style="grid-template-columns: 1fr;">
          <button class="btn-solid-gray" type="button" disabled>Tạm hết hàng</button>
        </div>
      )}

      <!-- Commitments -->
      <ul class="commitments-list">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-green"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          Uy tín – Chất lượng – Giá tốt nhất thị trường
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-green"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          Vận chuyển toàn quốc – Giao hàng nhanh chóng
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-green"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
          Quay video mở hộp khi nhận hàng để được hỗ trợ bảo hành
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-green"><path d="M3 2v6h6"></path><path d="M21 12A9 9 0 0 0 6 5.3L3 8"></path><path d="M21 22v-6h-6"></path><path d="M3 12a9 9 0 0 0 15 6.7l3-2.7"></path></svg>
          Đổi trả trong 7 ngày nếu sản phẩm lỗi
        </li>
      </ul>

      <!-- Description inline -->
      <div class="desc-module">
        <h3>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
          Mô tả sản phẩm
        </h3>
        <div class="desc-content">
          {descriptionLines.map((line) => (
            <p>{line}</p>
          ))}
        </div>
        <div class="desc-fade">
          <button class="btn-xem-them">Xem thêm ↓</button>
        </div>
      </div>
    </div>
  </section>

  {suggestedProducts.length > 0 && (
    <section class="product-suggestions" aria-labelledby="goi-y-heading">
      <div class="section-head-suggest">
        <span class="section-dot-suggest"></span>
        <h2 id="goi-y-heading">Sản phẩm gợi ý</h2>
      </div>

      <div class="products-grid">
        {suggestedProducts.map((item) => (
          <ProductCard product={item} />
        ))}
      </div>
    </section>
  )}

  <style>
    .summary-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
    }

    .badge-flash {
      display: inline-flex;
      padding: 4px 10px;
      background: #fef2f2;
      color: #dc2626;
      border: 1px solid #fecaca;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
    }

    .badge-popular {
      display: inline-flex;
      padding: 4px 10px;
      background: #fff7ed;
      color: #ea580c;
      border: 1px solid #fed7aa;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
    }

    .badge-instock {
      display: inline-flex;
      padding: 4px 10px;
      background: #f0fdf4;
      color: #16a34a;
      border: 1px solid #bbf7d0;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .badge-outofstock {
      display: inline-flex;
      padding: 4px 10px;
      background: #f1f5f9;
      color: #64748b;
      border: 1px solid #cbd5e1;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .btn-solid-gray {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 14px;
      background: #cbd5e1;
      color: #475569;
      font-weight: 700;
      font-size: 1rem;
      border-radius: 12px;
      cursor: not-allowed;
    }

    .gallery-main-wrap {
      position: relative;
    }

    .gallery-discount-badge {
      position: absolute;
      top: 14px;
      left: 14px;
      background: #dc2626;
      color: #fff;
      padding: 5px 12px;
      border-radius: 999px;
      font-size: 0.82rem;
      font-weight: 700;
    }

    .price-old-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 6px;
    }

    .price-old-row s {
      color: #94a3b8;
      font-size: 0.95rem;
    }

    .product-suggestions {
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid var(--line);
    }

    .section-head-suggest {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }

    .section-head-suggest h2 {
      margin: 0;
      font-size: 1.3rem;
      font-weight: 700;
    }

    .section-dot-suggest {
      display: block;
      width: 4px;
      height: 22px;
      border-radius: 4px;
      background: linear-gradient(180deg, var(--primary), var(--primary-dark));
      flex-shrink: 0;
    }

    @media (max-width: 640px) {
      .product-suggestions {
        margin-top: 20px;
        padding-top: 16px;
      }
    }
  </style>

  <script>
    const mainImage = document.getElementById("main-product-image") as HTMLImageElement;
    const thumbs = document.querySelectorAll(".thumb-btn");

    if (mainImage && thumbs.length > 0) {
      thumbs.forEach((thumb) => {
        thumb.addEventListener("click", () => {
          thumbs.forEach((t) => t.classList.remove("active"));
          thumb.classList.add("active");

          const newSrc = thumb.getAttribute("data-image");
          if (newSrc) {
            mainImage.src = newSrc;
          }
        });
      });
    }

    // Xem thêm button
    const btnXemThem = document.querySelector(".btn-xem-them");
    const descContent = document.querySelector(".desc-content");
    const descFade = document.querySelector(".desc-fade");

    if (btnXemThem && descContent && descFade) {
      btnXemThem.addEventListener("click", () => {
        descContent.classList.add("expanded");
        descFade.classList.add("hidden");
      });
    }

    // Mua ngay button
    const btnMuaNgay = document.querySelector(".btn-solid-red");
    if (btnMuaNgay) {
      btnMuaNgay.addEventListener("click", () => {
        const addToCartBtn = document.querySelector("[data-add-to-cart]") as HTMLButtonElement;
        if (addToCartBtn) {
          if (!addToCartBtn.classList.contains("is-added")) {
            addToCartBtn.click();
          }
          setTimeout(() => {
            window.location.href = "/cart";
          }, 300);
        } else {
          window.location.href = "/cart";
        }
      });
    }
  </script>
</MainLayout>
