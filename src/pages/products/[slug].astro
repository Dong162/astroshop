---
import MainLayout from "../../layouts/MainLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { formatCurrency, getProducts } from "../../lib/products";
import { toImageCdn } from "../../lib/image-cdn";
import type { Product } from "../../types/product";
import {
  buildBreadcrumbJsonLd,
  buildPageTitle,
  buildProductJsonLd,
  buildProductSeoDescription
} from "../../lib/seo";

export async function getStaticPaths() {
  const products = await getProducts({ all: true });
  const getSuggestedProducts = (currentProduct: Product, allProducts: Product[]): Product[] => {
    const activeProducts = allProducts.filter(item => item.stock_status !== "outofstock");
    const otherProducts = activeProducts.filter((item) => item.id !== currentProduct.id);

    const normalizedCategories = new Set(currentProduct.categories.map(c => c.toLowerCase()));
    
    const sameCategory = otherProducts.filter((item) =>
      item.categories.some((category) => normalizedCategories.has(category.toLowerCase()))
    );

    const fallback = otherProducts.filter(
      (item) => !sameCategory.some((candidate) => candidate.id === item.id)
    );

    // Return all relevant products, we'll limit display client-side
    return [...sameCategory, ...fallback].slice(0, 32); 
  };

  return products.map((product) => ({
    params: { slug: product.slug },
    props: {
      product,
      suggestedProducts: getSuggestedProducts(product, products)
    }
  }));
}

interface PageProps {
  product: Product;
  suggestedProducts: Product[];
}

const { product, suggestedProducts = [] } = Astro.props as PageProps;
const gallery =
  product.images.length > 0
    ? product.images.map(img => ({ src: toImageCdn(img.src) }))
    : [{ src: "https://placehold.co/1200x1200/f3f4f6/111827?text=Đông+Tạp+Hóa" }];
const displayPrice = product.sale_price ?? product.regular_price;
const descriptionLines = product.description.split("\n").filter(Boolean);
const siteUrl = Astro.site?.toString() ?? "https://example.com";
const seoTitle = buildPageTitle(product.name);
const seoDescription = buildProductSeoDescription(product);
const discountPercent = product.sale_price
  ? Math.max(1, Math.round((1 - product.sale_price / product.regular_price) * 100))
  : 0;
const productUrl = `/products/${product.slug}/`;
const structuredData = [
  buildBreadcrumbJsonLd([
    { name: "Trang chủ", url: new URL("/", siteUrl).toString() },
    ...(product.categories[0] ? [{ 
      name: product.categories[0], 
      url: new URL(`/search?q=${encodeURIComponent(product.categories[0])}`, siteUrl).toString() 
    }] : []),
    { name: product.name, url: new URL(productUrl, siteUrl).toString() }
  ]),
  buildProductJsonLd(product, siteUrl)
];
---

<MainLayout
  title={seoTitle}
  description={seoDescription}
  image={gallery[0].src}
  type="product"
  structuredData={structuredData}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Trang chủ</a>
    <span>›</span>
    {product.categories[0] && (
      <>
        <a href={`/search?q=${encodeURIComponent(product.categories[0])}`}>{product.categories[0]}</a>
        <span>›</span>
      </>
    )}
    <span>{product.name}</span>
  </nav>

  <section class="product-detail">
    <!-- Gallery -->
    <div class="product-detail__gallery">
      <div class="gallery-main-wrap">
        <img
          id="main-product-image"
          class="product-gallery__main"
          src={gallery[0].src}
          alt={product.name}
          loading="eager"
          fetchpriority="high"
          onerror="this.onerror=null; this.src=this.src.replace(/[_-]128x128|[_-]256x256|[_-]512x512/, '')"
        />
        {discountPercent > 0 && (
          <div class="gallery-discount-badge">-{discountPercent}%</div>
        )}
      </div>

      {gallery.length > 1 && (
        <div class="product-gallery__thumbs" id="product-thumbnails">
          {gallery.slice(0, 5).map((image, index) => (
            <button
              type="button"
              class={`thumb-btn ${index === 0 ? 'active' : ''}`}
              data-image={image.src}
              aria-label={`Xem ảnh ${index + 1}`}
            >
              <img 
                src={toImageCdn(image.src, "128x128")} 
                alt={`${product.name} - ảnh ${index + 1}`} 
                loading="lazy" 
                onerror="this.onerror=null; this.src=this.src.replace(/[_-]128x128|[_-]256x256|[_-]512x512/, '')"
              />
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- Summary -->
    <div class="product-detail__summary">
      <div class="summary-badges">
        {product.flash && <span class="badge-flash">⚡ Flash Sale</span>}
        {product.is_popular && <span class="badge-popular">🔥 Bán chạy</span>}
        {product.stock_status === "outofstock" ? (
          <span class="badge-outofstock">❌ Tạm hết hàng</span>
        ) : (
          <span class="badge-instock">✓ Còn hàng</span>
        )}
      </div>

      <h1>{product.name}</h1>

      <div class="rating-line">
        <span class="stars">★★★★★</span>
        <span class="score">5.0/5</span>
        <span class="rating-count">(1 đánh giá)</span>
      </div>

      <div class="price-block price-block--huge">
        <strong>{formatCurrency(displayPrice)}</strong>
        {product.sale_price && (
          <div class="price-old-row">
            <s>{formatCurrency(product.regular_price)}</s>
            <span class="discount-badge">Tiết kiệm {discountPercent}%</span>
          </div>
        )}
      </div>

      {product.short_description && (
        <p class="product-summary">{product.short_description}</p>
      )}

      <!-- CTA Buttons -->
      {product.stock_status !== "outofstock" ? (
        <div class="cta-panel-grid">
          <button
            class="btn-outline-blue"
            type="button"
            aria-label={`Thêm ${product.name} vào giỏ hàng`}
            data-add-to-cart
            data-added-text="Đã thêm vào giỏ"
            data-product-id={product.id}
            data-product-slug={product.slug}
            data-product-name={product.name}
            data-product-price={displayPrice}
            data-product-regular-price={product.regular_price}
            data-product-image={gallery[0].src}
            data-product-url={productUrl}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            <span data-add-to-cart-label>Thêm vào giỏ</span>
          </button>
          <button class="btn-solid-red" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            Mua ngay
          </button>
        </div>
      ) : (
        <div class="cta-panel-grid" style="grid-template-columns: 1fr;">
          <button class="btn-solid-gray" type="button" disabled>Tạm hết hàng</button>
        </div>
      )}

      <!-- Commitments -->
      <ul class="commitments-list">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-green"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          Uy tín – Chất lượng – Giá tốt nhất thị trường
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-green"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          Vận chuyển toàn quốc – Giao hàng nhanh chóng
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-green"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
          Quay video mở hộp khi nhận hàng để được hỗ trợ bảo hành
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-green"><path d="M3 2v6h6"></path><path d="M21 12A9 9 0 0 0 6 5.3L3 8"></path><path d="M21 22v-6h-6"></path><path d="M3 12a9 9 0 0 0 15 6.7l3-2.7"></path></svg>
          Đổi trả trong 7 ngày nếu sản phẩm lỗi
        </li>
      </ul>

      <!-- Description inline -->
      <div class="desc-module">
        <h3>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
          Mô tả sản phẩm
        </h3>
        <div class="desc-content">
          {descriptionLines.map((line) => (
            <p>{line}</p>
          ))}
        </div>
        <div class="desc-fade">
          <button class="btn-xem-them">Xem thêm ↓</button>
        </div>
      </div>
    </div>
  </section>

  {suggestedProducts.length > 0 && (
    <section class="product-suggestions" aria-labelledby="goi-y-heading" data-infinite-scroll-section>
      <div class="section-head-suggest">
        <span class="section-dot-suggest"></span>
        <h2 id="goi-y-heading">Sản phẩm gợi ý</h2>
      </div>

      <div class="products-grid" data-infinite-scroll-container>
        <!-- First batch rendered server-side for SEO and LCP -->
        {suggestedProducts.slice(0, 4).map((item) => (
          <ProductCard product={item} />
        ))}
      </div>

      <div class="infinite-scroll-trigger" data-scroll-trigger></div>
    </section>
  )}

  <!-- Template for client-side card injection -->
  <template data-product-card-template>
    <article class="product-card">
      <a class="product-card__image" data-product-link>
        <img data-product-image alt="" loading="lazy" onerror="this.onerror=null; this.src=this.src.replace(/[_-]128x128|[_-]256x256|[_-]512x512/, '')" />
        <div class="product-badge product-badge--red" data-product-badge-flash hidden>
          <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          Flash
        </div>
        <div class="product-badge product-badge--hot" data-product-badge-hot hidden>Nổi bật</div>
        <div class="product-discount-tag" data-product-discount hidden></div>
      </a>

      <div class="product-card__body">
        <div class="rating-line">
          <span class="stars">★★★★★</span>
          <span class="rating-count" data-product-rating-count></span>
        </div>

        <h3 class="product-title">
          <a data-product-link data-product-name></a>
        </h3>

        <div class="product-card__footer">
          <div class="price-container">
            <strong data-product-price></strong>
            <s data-product-regular hidden></s>
          </div>
          
          <button class="cart-add-btn" type="button" aria-label="Thêm vào giỏ hàng" data-product-cart-button>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          </button>
        </div>
      </div>
    </article>
  </template>

  <!-- Suggested products remaining data -->
  <script is:inline id="suggested-products-data" type="application/json" set:html={JSON.stringify(suggestedProducts.slice(4).map(p => ({
    id: p.id,
    slug: p.slug,
    name: p.name,
    regularPrice: p.regular_price,
    salePrice: p.sale_price,
    image: p.images[0]?.src ?? "",
    flash: p.flash,
    isPopular: p.is_popular
  }))).replace(/</g, '\\u003c')} />

  <style>
    .summary-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
    }

    .badge-flash {
      display: inline-flex;
      padding: 4px 10px;
      background: #fef2f2;
      color: #dc2626;
      border: 1px solid #fecaca;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .badge-popular {
      display: inline-flex;
      padding: 4px 10px;
      background: #fff7ed;
      color: #ea580c;
      border: 1px solid #fed7aa;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .badge-instock {
      display: inline-flex;
      padding: 4px 10px;
      background: #f0fdf4;
      color: #16a34a;
      border: 1px solid #bbf7d0;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 500;
    }

    .badge-outofstock {
      display: inline-flex;
      padding: 4px 10px;
      background: #f1f5f9;
      color: #64748b;
      border: 1px solid #cbd5e1;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 500;
    }

    .btn-solid-gray {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 14px;
      background: #cbd5e1;
      color: #475569;
      font-weight: 700;
      font-size: 1rem;
      border-radius: 12px;
      cursor: not-allowed;
    }

    .gallery-main-wrap {
      position: relative;
    }

    .gallery-discount-badge {
      position: absolute;
      top: 14px;
      left: 14px;
      background: #dc2626;
      color: #fff;
      padding: 5px 12px;
      border-radius: 999px;
      font-size: 0.82rem;
      font-weight: 700;
    }

    .price-old-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 6px;
    }

    .price-old-row s {
      color: #94a3b8;
      font-size: 0.95rem;
    }

    .product-suggestions {
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid var(--line);
    }

    .section-head-suggest {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }

    .section-head-suggest h2 {
      margin: 0;
      font-size: 1.3rem;
      font-weight: 700;
    }

    .section-dot-suggest {
      display: block;
      width: 4px;
      height: 22px;
      border-radius: 4px;
      background: linear-gradient(180deg, var(--primary), var(--primary-dark));
      flex-shrink: 0;
    }

    @media (max-width: 640px) {
      .product-suggestions {
        margin-top: 20px;
        padding-top: 16px;
      }
    }
  </style>

  <script>
    const mainImage = document.getElementById("main-product-image") as HTMLImageElement;
    const thumbs = document.querySelectorAll(".thumb-btn");

    if (mainImage && thumbs.length > 0) {
      thumbs.forEach((thumb) => {
        thumb.addEventListener("click", () => {
          thumbs.forEach((t) => t.classList.remove("active"));
          thumb.classList.add("active");

          const newSrc = thumb.getAttribute("data-image");
          if (newSrc) {
            mainImage.src = newSrc;
          }
        });
      });
    }

    // Xem thêm button
    const btnXemThem = document.querySelector(".btn-xem-them");
    const descContent = document.querySelector(".desc-content");
    const descFade = document.querySelector(".desc-fade");

    if (btnXemThem && descContent && descFade) {
      btnXemThem.addEventListener("click", () => {
        descContent.classList.add("expanded");
        descFade.classList.add("hidden");
      });
    }

    // Mua ngay button
    const btnMuaNgay = document.querySelector(".btn-solid-red");
    if (btnMuaNgay) {
      btnMuaNgay.addEventListener("click", () => {
        const addToCartBtn = document.querySelector("[data-add-to-cart]") as HTMLButtonElement;
        if (addToCartBtn) {
          if (!addToCartBtn.classList.contains("is-added")) {
            addToCartBtn.click();
          }
          setTimeout(() => {
            window.location.href = "/cart";
          }, 300);
        } else {
          window.location.href = "/cart";
        }
      });
    }

    // Infinite Scroll for Suggested Products
    const suggestSection = document.querySelector<HTMLElement>("[data-infinite-scroll-section]");
    if (suggestSection) {
      const suggestContainer = suggestSection.querySelector<HTMLElement>("[data-infinite-scroll-container]");
      const suggestTrigger = suggestSection.querySelector<HTMLElement>("[data-scroll-trigger]");
      const suggestTemplate = document.querySelector<HTMLTemplateElement>("template[data-product-card-template]");
      const suggestDataNode = document.getElementById("suggest-products-data") || document.getElementById("suggested-products-data");

      if (suggestContainer && suggestTrigger && suggestTemplate && suggestDataNode) {
        const suggestProducts = JSON.parse(suggestDataNode.textContent || "[]");
        const SUGGEST_PAGE_SIZE = 8;
        let suggestLoadedCount = 0;

        const formatter = new Intl.NumberFormat("vi-VN", {
          style: "currency",
          currency: "VND",
          maximumFractionDigits: 0
        });

        const createSuggestCard = (product: any) => {
          const frag = suggestTemplate.content.cloneNode(true) as DocumentFragment;
          const productUrl = `/products/${product.slug}/`;
          
          const links = frag.querySelectorAll<HTMLAnchorElement>("[data-product-link]");
          links.forEach(l => l.href = productUrl);

          const img = frag.querySelector<HTMLImageElement>("[data-product-image]");
          if (img) { 
            const mobileUrl = toImageCdn(product.image, "128x128");
            const desktopUrl = toImageCdn(product.image, "256x256");
            img.src = desktopUrl;
            img.srcset = `${mobileUrl} 128w, ${desktopUrl} 256w`;
            img.sizes = "(max-width: 768px) 128px, 256px";
            img.alt = product.name; 
          }

          const name = frag.querySelector<HTMLElement>("[data-product-name]");
          if (name) name.textContent = product.name;

          const flashBadge = frag.querySelector<HTMLElement>("[data-product-badge-flash]");
          if (flashBadge) flashBadge.hidden = !product.flash;

          const hotBadge = frag.querySelector<HTMLElement>("[data-product-badge-hot]");
          if (hotBadge) hotBadge.hidden = product.flash || !product.isPopular;

          const discount = frag.querySelector<HTMLElement>("[data-product-discount]");
          if (discount && product.salePrice) {
            const pct = Math.max(1, Math.round((1 - product.salePrice / product.regularPrice) * 100));
            discount.hidden = false;
            discount.textContent = `-${pct}%`;
          }

          const rating = frag.querySelector<HTMLElement>("[data-product-rating-count]");
          if (rating) rating.textContent = `(${(product.id % 5) + 3})`;

          const price = frag.querySelector<HTMLElement>("[data-product-price]");
          if (price) {
            const displayPrice = product.salePrice ?? product.regularPrice;
            price.textContent = formatter.format(displayPrice);
            price.classList.add(product.flash ? "price-red" : "price-blue");
          }

          const regular = frag.querySelector<HTMLElement>("[data-product-regular]");
          if (regular && product.salePrice) {
            regular.hidden = false;
            regular.textContent = formatter.format(product.regularPrice);
          }

          const cartBtn = frag.querySelector<HTMLButtonElement>("[data-product-cart-button]");
          if (cartBtn) {
            cartBtn.dataset.addToCart = "";
            cartBtn.dataset.productId = String(product.id);
            cartBtn.dataset.productSlug = product.slug;
            cartBtn.dataset.productName = product.name;
            cartBtn.dataset.productPrice = String(product.salePrice ?? product.regularPrice);
            cartBtn.dataset.productRegularPrice = String(product.regularPrice);
            cartBtn.dataset.productImage = toImageCdn(product.image, "256x256");
            cartBtn.dataset.productUrl = productUrl;
          }

          return frag;
        };

        const loadNextSuggestBatch = () => {
          const batch = suggestProducts.slice(suggestLoadedCount, suggestLoadedCount + SUGGEST_PAGE_SIZE);
          if (batch.length === 0) {
            suggestObserver.unobserve(suggestTrigger);
            return;
          }

          batch.forEach((p: any) => suggestContainer.appendChild(createSuggestCard(p)));
          suggestLoadedCount += batch.length;

          if (suggestLoadedCount >= suggestProducts.length) {
            suggestObserver.unobserve(suggestTrigger);
          }
        };

        const suggestObserver = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting && suggestLoadedCount < suggestProducts.length) {
            loadNextSuggestBatch();
          }
        }, { rootMargin: "400px" });

        suggestObserver.observe(suggestTrigger);
      }
    }
  </script>
</MainLayout>
